@inherits LayoutComponentBase
@implements IDisposable
@inject WebAuthSession Auth
@inject NavigationManager Navigation

@if (!Auth.IsInitialized)
{
    <div class="shell">
        <main class="shell-content">
            <article class="panel auth-shell">
                <h2>InvoiceWizard wird vorbereitet</h2>
                <p>Die Sitzung und die Firmenzuordnung werden geladen.</p>
            </article>
        </main>
    </div>
}
else if (!Auth.IsAuthenticated)
{
    <div class="shell">
        <main class="shell-content">
            <AuthGate />
        </main>
    </div>
}
else if (!Auth.HasMobileAccess)
{
    <div class="shell">
        <main class="shell-content">
            <article class="panel auth-shell">
                <h2>Mobiler Zugriff ist im Tarif nicht enthalten</h2>
                <p>Dein aktueller Tarif erlaubt keinen Zugriff auf die mobile Web-App. Bitte passe die Lizenz an.</p>
                <button class="ghost-button" @onclick="Auth.LogoutAsync">Abmelden</button>
            </article>
        </main>
    </div>
}
else
{
    <div class="shell app-shell">
        <header class="app-topbar compact-web-topbar">
            <button class="ghost-button nav-toggle" @onclick="ToggleNavigationAsync">Menü</button>
        </header>

        <div class="app-body">
            @if (IsNavigationOpen)
            {
                <button type="button" class="nav-overlay" @onclick="CloseNavigationAsync" aria-label="Navigation schließen"></button>
            }

            <NavMenu IsOpen="@IsNavigationOpen" />

            <main class="shell-content app-main-content">
                <article class="panel" @key="Auth.CurrentSession?.AccessToken">
                    @Body
                </article>
            </main>
        </div>
    </div>
}

@code {
    private bool IsNavigationOpen { get; set; }

    protected override void OnInitialized()
    {
        Auth.StateChanged += HandleAuthChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        IsNavigationOpen = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.EnsureInitializedAsync();
        }
    }

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);

    private Task ToggleNavigationAsync()
    {
        IsNavigationOpen = !IsNavigationOpen;
        return Task.CompletedTask;
    }

    private Task CloseNavigationAsync()
    {
        IsNavigationOpen = false;
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        Auth.StateChanged -= HandleAuthChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        IsNavigationOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }
}
