@inherits LayoutComponentBase
@implements IDisposable
@inject WebAuthSession Auth

@if (!Auth.IsInitialized)
{
    <div class="shell">
        <main class="shell-content">
            <article class="panel auth-shell">
                <h2>InvoiceWizard wird vorbereitet</h2>
                <p>Die Sitzung und die Firmenzuordnung werden geladen.</p>
            </article>
        </main>
    </div>
}
else if (!Auth.IsAuthenticated)
{
    <div class="shell">
        <main class="shell-content">
            <AuthGate />
        </main>
    </div>
}
else if (!Auth.HasMobileAccess)
{
    <div class="shell">
        <main class="shell-content">
            <article class="panel auth-shell">
                <h2>Mobiler Zugriff ist im Tarif nicht enthalten</h2>
                <p>Dein aktueller Tarif erlaubt keinen Zugriff auf die mobile Web-App. Bitte passe die Lizenz an.</p>
                <button class="ghost-button" @onclick="Auth.LogoutAsync">Abmelden</button>
            </article>
        </main>
    </div>
}
else
{
    <div class="shell app-shell">
        <header class="app-topbar">
            <div class="row-actions wrap-mobile app-topbar-actions">
                <button class="ghost-button nav-toggle" @onclick="ToggleNavigationAsync">Menue</button>
                <span class="pill">@Auth.CurrentSession!.Tenant.Name</span>
            </div>
            <div class="shell-session">
                <p class="shell-copy">@Auth.CurrentSession.User.DisplayName (@Auth.CurrentSession.User.Role)</p>
                <div class="row-actions wrap-mobile">
                    <span class="pill">@Auth.CurrentSession.License?.PlanName</span>
                    <button class="ghost-button" @onclick="Auth.LogoutAsync">Abmelden</button>
                </div>
            </div>
        </header>

        <div class="app-body">
            @if (IsNavigationOpen)
            {
                <button type="button" class="nav-overlay" @onclick="CloseNavigationAsync" aria-label="Navigation schliessen"></button>
            }

            <NavMenu IsOpen="@IsNavigationOpen" OnNavigate="CloseNavigationAsync" />

            <main class="shell-content">
                <article class="panel" @key="Auth.CurrentSession?.AccessToken">
                    @Body
                </article>
            </main>
        </div>
    </div>
}

@code {
    private bool IsNavigationOpen { get; set; }

    protected override void OnInitialized()
    {
        Auth.StateChanged += HandleAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.EnsureInitializedAsync();
        }
    }

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);

    private Task ToggleNavigationAsync()
    {
        IsNavigationOpen = !IsNavigationOpen;
        return Task.CompletedTask;
    }

    private Task CloseNavigationAsync()
    {
        IsNavigationOpen = false;
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        Auth.StateChanged -= HandleAuthChanged;
    }
}
