@using Microsoft.JSInterop
@inject WebAuthSession Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS

<aside id="app-nav-drawer" class="nav-drawer @(IsOpen ? "open" : string.Empty)">
    <nav class="nav-menu">
        <div class="nav-brand-block">
            <strong class="nav-brand-title">@Auth.CurrentSession?.Tenant.Name</strong>
            <span class="nav-brand-copy">@Auth.CurrentSession?.User.DisplayName</span>
            <span class="nav-brand-copy">@Auth.CurrentSession?.User.Role</span>
            @if (!string.IsNullOrWhiteSpace(Auth.CurrentSession?.License?.PlanName))
            {
                <span class="pill nav-license-pill">@Auth.CurrentSession!.License!.PlanName</span>
            }
        </div>

        <div class="nav-group">
            <span class="nav-group-label">Übersicht</span>
            <button type="button" class="@GetNavButtonClass("/")" @onclick='() => NavigateToAsync("/")'>Status</button>
            <button type="button" class="@GetNavButtonClass("/analytics")" @onclick='() => NavigateToAsync("/analytics")'>Auswertung</button>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">Tagesgeschäft</span>
            <button type="button" class="@GetNavButtonClass("/worktime")" @onclick='() => NavigateToAsync("/worktime")'>Arbeitszeit</button>
            <button type="button" class="@GetNavButtonClass("/calendar")" @onclick='() => NavigateToAsync("/calendar")'>Kalender</button>
            <button type="button" class="@GetNavButtonClass("/notes")" @onclick='() => NavigateToAsync("/notes")'>Notizen</button>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">Stammdaten</span>
            <button type="button" class="@GetNavButtonClass("/customers")" @onclick='() => NavigateToAsync("/customers")'>Kunden</button>
            <button type="button" class="@GetNavButtonClass("/projectdata")" @onclick='() => NavigateToAsync("/projectdata")'>Projektdaten</button>
        </div>

        <div class="nav-group">
            <span class="nav-group-label">App</span>
            <button type="button" class="ghost-button nav-utility-button" @onclick="InstallAppAsync">App installieren</button>
            @if (!string.IsNullOrWhiteSpace(InstallMessage))
            {
                <span class="nav-install-hint">@InstallMessage</span>
            }
        </div>

        <button type="button" class="ghost-button nav-logout-button" @onclick="LogoutAndNavigateAsync">Abmelden</button>
    </nav>
</aside>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnNavigate { get; set; }
    private string? InstallMessage { get; set; }

    private async Task NavigateToAsync(string href)
    {
        await OnNavigate.InvokeAsync();
        Navigation.NavigateTo(href);
    }

    private async Task LogoutAndNavigateAsync()
    {
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task InstallAppAsync()
    {
        var result = await JS.InvokeAsync<string>("invoiceWizardPwa.install");
        InstallMessage = result switch
        {
            "prompted" => "Installationsdialog geöffnet.",
            "accepted" => "App wird installiert.",
            "installed" => "Die App ist bereits installiert.",
            "ios" => "Auf iPhone/iPad bitte im Browser auf Teilen und dann Zum Home-Bildschirm tippen.",
            _ => "Installation aktuell nicht verfügbar. Bitte Seite einmal normal im Browser öffnen und erneut versuchen."
        };
    }

    private string GetNavButtonClass(string href)
        => $"nav-pill-button{(IsActive(href) ? " active" : string.Empty)}";

    private bool IsActive(string href)
    {
        var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var normalizedCurrent = string.IsNullOrWhiteSpace(currentPath) ? "/" : "/" + currentPath.Trim('/');
        return href == "/"
            ? normalizedCurrent == "/"
            : normalizedCurrent.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }
}
