@inject WebAuthSession Auth
@inject NavigationManager Navigation

<aside class="nav-drawer @(IsOpen ? "open" : string.Empty)">
    <nav class="nav-menu">
        <NavLink href="/" Match="NavLinkMatch.All" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Status</NavLink>
        <NavLink href="/worktime" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Arbeitszeit</NavLink>
        <NavLink href="/customers" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Kunden</NavLink>
        <NavLink href="/projectdata" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Projektdaten</NavLink>
        <NavLink href="/calendar" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Kalender</NavLink>
        <NavLink href="/notes" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Notizen</NavLink>
        <NavLink href="/analytics" class="nav-pill-button" ActiveClass="active" @onclick="HandleNavigateAsync">Auswertung</NavLink>
    </nav>
</aside>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnNavigate { get; set; }

    private Task HandleNavigateAsync()
        => OnNavigate.InvokeAsync();
}
