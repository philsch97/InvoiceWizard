@page "/notes"
@using Microsoft.JSInterop
@inject BackendApiClient Api
@inject WebAuthSession Auth
@inject IJSRuntime JS
@inject WebUiSelectionState UiState

<PageTitle>Notizen &amp; ToDos</PageTitle>

<section class="page-section notes-page">
    <div class="section-heading">
        <div>
            <h2>Notizen &amp; ToDos</h2>
            <p>Listen mobil übersichtlich pflegen. Tippe auf eine Liste, um sie zu öffnen.</p>
        </div>
        <button class="action-button secondary" @onclick="ReloadAsync">Aktualisieren</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="inline-status">@StatusMessage</div>
    }

    <article class="feature-card">
        <div class="form-grid selector-grid">
            <label>
                <span>Kunde</span>
                <select @bind="SelectedCustomerId" @bind:after="OnCustomerChangedAsync">
                    <option value="">Bitte wählen</option>
                    @foreach (var customer in Customers)
                    {
                        <option value="@customer.CustomerId">@customer.Name</option>
                    }
                </select>
            </label>
            <label>
                <span>Projekt</span>
                <select @bind="SelectedProjectId" @bind:after="ReloadListsAsync">
                    <option value="">Alle Projekte</option>
                    @foreach (var project in Projects)
                    {
                        <option value="@project.ProjectId">@project.Name</option>
                    }
                </select>
            </label>
            <label class="wide">
                <span>Neue Liste</span>
                <div class="inline-editor">
                    <input @bind="NewListTitle" placeholder="z. B. Restpunkte Küche" />
                    <button class="action-button" @onclick="CreateListAsync" disabled="@(!SelectedCustomerId.HasValue)">Liste anlegen</button>
                </div>
            </label>
        </div>
    </article>

    <article class="list-card">
        <div class="table-header compact">
            <h3>Listen</h3>
            <span>@Lists.Count Einträge</span>
        </div>

        @if (Lists.Count == 0)
        {
            <p class="empty-hint">Noch keine Liste vorhanden.</p>
        }
        else
        {
            @foreach (var list in Lists)
            {
                <button type="button" class="list-row stacked-mobile selectable-list-row" @onclick="() => OpenListDialog(list)">
                    <div>
                        <strong>@list.Title</strong>
                        <p>@list.CustomerName · @(list.ProjectName ?? "Ohne Projekt")</p>
                    </div>
                    <div class="row-actions wrap-mobile">
                        <span class="pill">@list.OpenItemCount offen</span>
                        <span class="pill">@list.CompletedItemCount erledigt</span>
                    </div>
                </button>
            }
        }
    </article>
</section>

@if (ShowListDialog && SelectedList is not null)
{
    <div class="modal-backdrop" @onclick="CloseListDialog">
        <div class="modal-card list-editor-modal" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>@SelectedList.Title</h3>
                    <p>@SelectedList.CustomerName · @(SelectedList.ProjectName ?? "Ohne Projekt")</p>
                </div>
                <div class="row-actions wrap-mobile">
                    <span class="pill">@SelectedList.OpenItemCount offen</span>
                    <button class="ghost-button danger" @onclick="ConfirmDeleteList">Liste löschen</button>
                </div>
            </div>

            <label class="wide">
                <span>Neuer Punkt / Unterpunkt</span>
                <input @bind="NewItemText" placeholder="z. B. Steckdosenabdeckung nachbestellen" />
            </label>

            <div class="split-action-row">
                <button class="action-button half-width-button" @onclick="CreateRootItemAsync">Punkt anlegen</button>
                <button class="ghost-button half-width-button" @onclick="CreateChildItemAsync" disabled="@(SelectedItemId is null)">Unterpunkt</button>
            </div>

            <div class="todo-tree">
                @foreach (var item in SelectedList.Items.OrderBy(x => x.SortOrder))
                {
                    @RenderTodoItem(item, 0)
                }
            </div>

            <div class="attachments-block">
                <div class="table-header compact">
                    <h3>Bilder</h3>
                    <span>@SelectedList.Attachments.Count Einträge</span>
                </div>

                <div class="form-grid compact-grid">
                    <label class="wide">
                        <span>Beschriftung</span>
                        <input @bind="AttachmentCaption" />
                    </label>

                    <div class="attachment-pick-status wide">
                        <span>@SelectedAttachmentFileName</span>
                    </div>

                    <InputFile id="@CameraInputId" @key="@CameraInputKey" class="hidden-file-input" OnChange="HandleFileSelected" accept="image/*" capture="environment" />
                    <InputFile id="@FileInputId" @key="@FileInputKey" class="hidden-file-input" OnChange="HandleFileSelected" accept="image/*" />

                    <div class="split-action-row wide">
                        <button type="button" class="action-button half-width-button" @onclick="TriggerCameraPickerAsync">Foto aufnehmen</button>
                        <button type="button" class="ghost-button half-width-button" @onclick="TriggerFilePickerAsync">Datei auswählen</button>
                    </div>

                    <button class="action-button wide" @onclick="UploadAttachmentAsync" disabled="@(SelectedAttachmentFile is null)">Bild hochladen</button>
                </div>

                @foreach (var attachment in SelectedList.Attachments.OrderByDescending(x => x.UploadedAt))
                {
                    <div class="list-row stacked-mobile">
                        <div>
                            <strong>@attachment.FileName</strong>
                            <p>@(string.IsNullOrWhiteSpace(attachment.Caption) ? "Ohne Beschriftung" : attachment.Caption)</p>
                        </div>
                        <div class="row-actions wrap-mobile">
                            <button class="ghost-button" @onclick="() => OpenAttachmentPreviewAsync(attachment)">Ansehen</button>
                            <button class="ghost-button danger" @onclick="() => DeleteAttachmentAsync(attachment.TodoAttachmentId)">Löschen</button>
                        </div>
                    </div>
                }
            </div>

            <div class="row-actions wrap-mobile modal-actions">
                <button class="ghost-button" @onclick="CloseListDialog">Schließen</button>
            </div>
        </div>
    </div>
}

@if (ShowItemActionsDialog && ActionItem is not null)
{
    <div class="modal-backdrop" @onclick="CloseItemActionsDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>Punkt-Aktionen</h3>
                    <p>@ActionItem.Text</p>
                </div>
            </div>
            <div class="row-actions wrap-mobile">
                <button class="ghost-button danger" @onclick="DeleteActionItemAsync">Löschen</button>
                <button class="ghost-button" @onclick="CloseItemActionsDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@if (ShowDeleteListDialog && SelectedList is not null)
{
    <div class="modal-backdrop" @onclick="CloseDeleteListDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>Liste löschen</h3>
                    <p>Soll die Liste „@SelectedList.Title“ wirklich gelöscht werden?</p>
                </div>
            </div>
            <div class="row-actions wrap-mobile">
                <button class="ghost-button danger" @onclick="DeleteSelectedListAsync">Ja, löschen</button>
                <button class="ghost-button" @onclick="CloseDeleteListDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@if (ShowAttachmentPreview && !string.IsNullOrWhiteSpace(PreviewImageUrl))
{
    <div class="modal-backdrop" @onclick="CloseAttachmentPreview">
        <div class="modal-card image-preview-modal" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>@PreviewAttachmentName</h3>
                    <p>Bildvorschau</p>
                </div>
                <button class="ghost-button" @onclick="CloseAttachmentPreview">Schließen</button>
            </div>
            <img src="@PreviewImageUrl" alt="@PreviewAttachmentName" class="attachment-preview-image" />
        </div>
    </div>
}

@code {
    private List<CustomerItem> Customers { get; set; } = [];
    private List<ProjectItem> Projects { get; set; } = [];
    private List<TodoListItem> Lists { get; set; } = [];
    private TodoListItem? SelectedList { get; set; }
    private int? SelectedCustomerId { get; set; }
    private int? SelectedProjectId { get; set; }
    private int? SelectedItemId { get; set; }
    private string NewListTitle { get; set; } = string.Empty;
    private string NewItemText { get; set; } = string.Empty;
    private string AttachmentCaption { get; set; } = string.Empty;
    private IBrowserFile? SelectedAttachmentFile { get; set; }
    private string? StatusMessage { get; set; }
    private bool ShowListDialog { get; set; }
    private bool ShowDeleteListDialog { get; set; }
    private bool ShowItemActionsDialog { get; set; }
    private bool ShowAttachmentPreview { get; set; }
    private string? PreviewImageUrl { get; set; }
    private string PreviewAttachmentName { get; set; } = string.Empty;
    private TodoItem? ActionItem { get; set; }
    private CancellationTokenSource? ItemPressCancellation { get; set; }
    private bool SuppressNextSelection { get; set; }
    private int AttachmentInputVersion { get; set; }
    private string CameraInputId => $"todo-camera-{AttachmentInputVersion}";
    private string FileInputId => $"todo-file-{AttachmentInputVersion}";
    private string CameraInputKey => $"camera-{AttachmentInputVersion}";
    private string FileInputKey => $"file-{AttachmentInputVersion}";
    private string SelectedAttachmentFileName => SelectedAttachmentFile?.Name ?? "Keine ausgewählt";

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsInitialized || !Auth.IsAuthenticated)
        {
            Customers = [];
            Projects = [];
            Lists = [];
            SelectedCustomerId = null;
            SelectedProjectId = null;
            SelectedList = null;
            return;
        }

        Customers = (await Api.GetCustomersAsync(activeProjectsOnly: true)).OrderBy(x => x.Name).ToList();
        if (UiState.SelectedCustomerId.HasValue && Customers.Any(x => x.CustomerId == UiState.SelectedCustomerId.Value))
        {
            SelectedCustomerId = UiState.SelectedCustomerId.Value;
        }
        else if (!SelectedCustomerId.HasValue && Customers.Count > 0)
        {
            SelectedCustomerId = Customers[0].CustomerId;
        }

        await OnCustomerChangedAsync();
    }

    private async Task OnCustomerChangedAsync()
    {
        UiState.SetSelectedCustomer(SelectedCustomerId);
        Projects = SelectedCustomerId.HasValue ? (await Api.GetProjectsAsync(SelectedCustomerId.Value, includeInactive: false)).OrderBy(x => x.Name).ToList() : [];
        if (SelectedProjectId.HasValue && Projects.All(x => x.ProjectId != SelectedProjectId.Value))
        {
            SelectedProjectId = null;
        }

        await ReloadListsAsync();
    }

    private async Task ReloadAsync()
    {
        Customers = (await Api.GetCustomersAsync(activeProjectsOnly: true)).OrderBy(x => x.Name).ToList();
        if (SelectedCustomerId.HasValue)
        {
            Projects = (await Api.GetProjectsAsync(SelectedCustomerId.Value, includeInactive: false)).OrderBy(x => x.Name).ToList();
        }

        await ReloadListsAsync();
    }

    private async Task ReloadListsAsync()
    {
        if (!SelectedCustomerId.HasValue)
        {
            Lists = [];
            SelectedList = null;
            ShowListDialog = false;
            return;
        }

        Lists = (await Api.GetTodoListsAsync(SelectedCustomerId.Value, SelectedProjectId)).OrderByDescending(x => x.UpdatedAt).ToList();
        if (SelectedList is not null)
        {
            SelectedList = Lists.FirstOrDefault(x => x.TodoListId == SelectedList.TodoListId);
        }

        if (SelectedList is null && ShowListDialog)
        {
            ShowListDialog = false;
        }

        SelectedItemId = SelectedList?.Items.SelectMany(FlattenTodoItems).FirstOrDefault(x => x.TodoItemId == SelectedItemId)?.TodoItemId;
    }

    private void OpenListDialog(TodoListItem list)
    {
        SelectedList = list;
        SelectedItemId = null;
        ShowListDialog = true;
    }

    private void CloseListDialog()
    {
        ShowListDialog = false;
        SelectedItemId = null;
        CloseItemActionsDialog();
        ResetAttachmentSelection();
    }

    private async Task CreateListAsync()
    {
        if (!SelectedCustomerId.HasValue || string.IsNullOrWhiteSpace(NewListTitle))
        {
            StatusMessage = "Bitte Kunde und Listentitel angeben.";
            return;
        }

        SelectedList = await Api.CreateTodoListAsync(SelectedCustomerId.Value, SelectedProjectId, NewListTitle.Trim());
        NewListTitle = string.Empty;
        ShowListDialog = true;
        StatusMessage = $"Liste {SelectedList.Title} gespeichert.";
        await ReloadListsAsync();
    }

    private void ConfirmDeleteList()
    {
        ShowDeleteListDialog = true;
    }

    private void CloseDeleteListDialog()
    {
        ShowDeleteListDialog = false;
    }

    private async Task DeleteSelectedListAsync()
    {
        if (SelectedList is null)
        {
            return;
        }

        var todoListId = SelectedList.TodoListId;
        await Api.DeleteTodoListAsync(todoListId);
        SelectedList = null;
        SelectedItemId = null;
        ShowListDialog = false;
        ShowDeleteListDialog = false;
        StatusMessage = "Liste gelöscht.";
        await ReloadListsAsync();
    }

    private async Task CreateRootItemAsync()
    {
        if (SelectedList is null || string.IsNullOrWhiteSpace(NewItemText))
        {
            StatusMessage = "Bitte zuerst eine Liste und einen Text angeben.";
            return;
        }

        SelectedList = await Api.CreateTodoItemAsync(SelectedList.TodoListId, NewItemText.Trim());
        NewItemText = string.Empty;
        StatusMessage = "Punkt angelegt.";
        await ReloadListsAsync();
    }

    private async Task CreateChildItemAsync()
    {
        if (SelectedList is null || SelectedItemId is null || string.IsNullOrWhiteSpace(NewItemText))
        {
            StatusMessage = "Bitte einen ausgewählten Punkt und einen Text für den Unterpunkt angeben.";
            return;
        }

        SelectedList = await Api.CreateTodoItemAsync(SelectedList.TodoListId, NewItemText.Trim(), SelectedItemId);
        NewItemText = string.Empty;
        StatusMessage = "Unterpunkt angelegt.";
        await ReloadListsAsync();
    }

    private async Task ToggleItemAsync(TodoItem item)
    {
        if (SelectedList is null)
        {
            return;
        }

        SelectedList = await Api.UpdateTodoItemStateAsync(item.TodoItemId, !item.IsCompleted);
        StatusMessage = item.IsCompleted ? "Punkt wieder geöffnet." : "Punkt als erledigt markiert.";
        await ReloadListsAsync();
    }

    private void SelectItem(TodoItem item)
    {
        if (SuppressNextSelection && ActionItem?.TodoItemId == item.TodoItemId)
        {
            SuppressNextSelection = false;
            return;
        }

        SelectedItemId = item.TodoItemId;
    }

    private async Task DeleteItemAsync(TodoItem item)
    {
        if (SelectedList is null)
        {
            return;
        }

        SelectedList = await Api.DeleteTodoItemAsync(item.TodoItemId);
        if (SelectedItemId == item.TodoItemId)
        {
            SelectedItemId = null;
        }

        StatusMessage = "Punkt gelöscht.";
        await ReloadListsAsync();
    }

    private async Task StartItemPressAsync(TodoItem item)
    {
        CancelItemPress();
        var cancellation = new CancellationTokenSource();
        ItemPressCancellation = cancellation;

        try
        {
            await Task.Delay(650, cancellation.Token);
            ActionItem = item;
            ShowItemActionsDialog = true;
            SuppressNextSelection = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void EndItemPress()
    {
        CancelItemPress();
    }

    private void CloseItemActionsDialog()
    {
        ShowItemActionsDialog = false;
        ActionItem = null;
        SuppressNextSelection = false;
        CancelItemPress();
    }

    private async Task DeleteActionItemAsync()
    {
        if (ActionItem is null)
        {
            return;
        }

        var item = ActionItem;
        CloseItemActionsDialog();
        await DeleteItemAsync(item);
    }

    private void CancelItemPress()
    {
        if (ItemPressCancellation is null)
        {
            return;
        }

        ItemPressCancellation.Cancel();
        ItemPressCancellation.Dispose();
        ItemPressCancellation = null;
    }

    private void HandleFileSelected(InputFileChangeEventArgs args)
    {
        SelectedAttachmentFile = args.File;
    }

    private async Task TriggerCameraPickerAsync()
    {
        await JS.InvokeVoidAsync("invoiceWizardUi.clickById", CameraInputId);
    }

    private async Task TriggerFilePickerAsync()
    {
        await JS.InvokeVoidAsync("invoiceWizardUi.clickById", FileInputId);
    }

    private async Task UploadAttachmentAsync()
    {
        if (SelectedList is null || SelectedAttachmentFile is null)
        {
            StatusMessage = "Bitte zuerst eine Liste und eine Bilddatei auswählen.";
            return;
        }

        SelectedList = await Api.UploadTodoAttachmentAsync(SelectedList.TodoListId, SelectedAttachmentFile, AttachmentCaption);
        AttachmentCaption = string.Empty;
        ResetAttachmentSelection();
        StatusMessage = "Bild hochgeladen.";
        await ReloadListsAsync();
    }

    private async Task DeleteAttachmentAsync(int attachmentId)
    {
        SelectedList = await Api.DeleteTodoAttachmentAsync(attachmentId);
        StatusMessage = "Bild gelöscht.";
        await ReloadListsAsync();
    }

    private async Task OpenAttachmentPreviewAsync(TodoAttachmentItem attachment)
    {
        var content = await Api.GetTodoAttachmentContentAsync(attachment.TodoAttachmentId);
        PreviewImageUrl = $"data:{content.ContentType};base64,{Convert.ToBase64String(content.Data)}";
        PreviewAttachmentName = string.IsNullOrWhiteSpace(content.FileName) ? attachment.FileName : content.FileName;
        ShowAttachmentPreview = true;
    }

    private void CloseAttachmentPreview()
    {
        PreviewImageUrl = null;
        PreviewAttachmentName = string.Empty;
        ShowAttachmentPreview = false;
    }

    private void ResetAttachmentSelection()
    {
        SelectedAttachmentFile = null;
        AttachmentInputVersion++;
    }

    private IEnumerable<TodoItem> FlattenTodoItems(TodoItem item)
    {
        yield return item;
        foreach (var child in item.Children.SelectMany(FlattenTodoItems))
        {
            yield return child;
        }
    }

    private RenderFragment RenderTodoItem(TodoItem item, int depth) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", $"todo-item {(SelectedItemId == item.TodoItemId ? "selected-todo" : string.Empty)}");
        builder.AddAttribute(sequence++, "style", $"margin-left:{depth * 12}px");

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "todo-item-row");

        builder.OpenElement(sequence++, "input");
        builder.AddAttribute(sequence++, "class", "todo-checkbox");
        builder.AddAttribute(sequence++, "type", "checkbox");
        builder.AddAttribute(sequence++, "checked", item.IsCompleted);
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create(this, () => ToggleItemAsync(item)));
        builder.CloseElement();

        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "todo-text-button");
        builder.AddAttribute(sequence++, "onpointerdown", EventCallback.Factory.Create<PointerEventArgs>(this, () => StartItemPressAsync(item)));
        builder.AddAttribute(sequence++, "onpointerup", EventCallback.Factory.Create<PointerEventArgs>(this, _ => EndItemPress()));
        builder.AddAttribute(sequence++, "onpointerleave", EventCallback.Factory.Create<PointerEventArgs>(this, _ => EndItemPress()));
        builder.AddAttribute(sequence++, "onpointercancel", EventCallback.Factory.Create<PointerEventArgs>(this, _ => EndItemPress()));
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => SelectItem(item)));
        builder.AddContent(sequence++, item.Text);
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();

        foreach (var child in item.Children.OrderBy(x => x.SortOrder))
        {
            builder.AddContent(sequence++, RenderTodoItem(child, depth + 1));
        }
    };
}
