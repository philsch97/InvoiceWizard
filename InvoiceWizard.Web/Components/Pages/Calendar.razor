@page "/calendar"
@inject BackendApiClient Api
@inject WebAuthSession Auth
@inject WebOfflineDataService Offline

<PageTitle>Kalender</PageTitle>

<section class="page-section calendar-page">
    <div class="section-heading">
        <div>
            <h2>Kalender</h2>
            <p>Zwischen Tag und Woche wechseln, Termine mobil prüfen und den Editor nur dann öffnen, wenn du ihn wirklich brauchst.</p>
        </div>
        <button class="action-button secondary" @onclick="ReloadAsync">Aktualisieren</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="inline-status @(StatusIsWarning ? "warning" : string.Empty)">@StatusMessage</div>
    }

    <article class="feature-card">
        <div class="form-grid selector-grid">
            <label>
                <span>Kalender</span>
                <select @bind="SelectedUserId" @bind:after="OnUserChangedAsync">
                    @foreach (var user in Users)
                    {
                        <option value="@user.AppUserId">@user.DisplayName</option>
                    }
                </select>
            </label>
            <label>
                <span>Tag</span>
                <input type="date" value="@SelectedDateText" @onchange="OnSelectedDateChanged" />
            </label>
        </div>

        <div class="row-actions wrap-mobile">
            <button class="ghost-button @(ViewMode == CalendarViewMode.Day ? "active-pill" : string.Empty)" @onclick="() => ChangeViewAsync(CalendarViewMode.Day)">Tag</button>
            <button class="ghost-button @(ViewMode == CalendarViewMode.Week ? "active-pill" : string.Empty)" @onclick="() => ChangeViewAsync(CalendarViewMode.Week)">Woche</button>
            <button class="ghost-button" @onclick="MoveBackwardAsync">Zurück</button>
            <button class="ghost-button" @onclick="MoveForwardAsync">Weiter</button>
            <button class="ghost-button" @onclick="GoToTodayAsync">Heute</button>
        </div>

        <div class="compact-info-grid">
            <div class="compact-info-card">
                <span>Gewählter Kalender</span>
                <strong>@(SelectedUser?.DisplayName ?? "Nicht gewählt")</strong>
            </div>
            <div class="compact-info-card">
                <span>Ansicht</span>
                <strong>@(ViewMode == CalendarViewMode.Day ? "Tag" : "Woche")</strong>
            </div>
            <div class="compact-info-card">
                <span>Gewählter Tag</span>
                <strong>@SelectedDate.ToString("dd.MM.yyyy")</strong>
            </div>
            <div class="compact-info-card">
                <span>Bearbeitbar</span>
                <strong>@(CanEditSelectedUser ? "Ja" : "Nein")</strong>
            </div>
        </div>

        <p class="empty-hint">
            @(CanEditSelectedUser
                ? "Dein Kalender ist bearbeitbar. Ein Klick auf einen Tag oder der Button rechts unten öffnet den Termin-Dialog."
                : $"Du siehst den Kalender von {SelectedUser?.DisplayName ?? "dem Team"} im Lesemodus.")
        </p>
    </article>

    @if (ViewMode == CalendarViewMode.Week)
    {
        <article class="list-card">
            <div class="table-header">
                <h3>Woche @WeekStart.ToString("dd.MM.") - @WeekStart.AddDays(6).ToString("dd.MM.yyyy")</h3>
                <span>@WeekCards.Sum(x => x.Entries.Count) Termine</span>
            </div>

            <div class="calendar-week-grid">
                @foreach (var day in WeekCards)
                {
                    <button type="button" class="calendar-day-card @(day.Date.Date == SelectedDate.Date ? "selected-day" : string.Empty)" @onclick="() => SelectDayAsync(day.Date)">
                        <div class="calendar-day-header">
                            <strong>@day.Date.ToString("ddd")</strong>
                            <span>@day.Date.ToString("dd.MM.")</span>
                        </div>

                        @if (day.Entries.Count == 0)
                        {
                            <span class="empty-hint">Keine Termine</span>
                        }
                        else
                        {
                            @foreach (var entry in day.Entries.Take(4))
                            {
                                <div class="calendar-chip" @onclick:stopPropagation="true" @onclick="() => OpenDetailsDialog(entry)">
                                    <strong>@entry.StartTime.ToString(@"hh\:mm")</strong>
                                    <span>@entry.Title</span>
                                </div>
                            }

                            @if (day.Entries.Count > 4)
                            {
                                <span class="pill">@($"{day.Entries.Count - 4} weitere")</span>
                            }
                        }
                    </button>
                }
            </div>
        </article>
    }

    <article class="list-card">
        <div class="table-header">
            <div>
                <h3>Termine am @SelectedDate.ToString("dd.MM.yyyy")</h3>
                <p>@Entries.Count Einträge</p>
            </div>
            @if (CanEditSelectedUser)
            {
                <button class="action-button" @onclick="() => OpenCreateDialog(SelectedDate)">Termin anlegen</button>
            }
        </div>

        @if (Entries.Count == 0)
        {
            <p class="empty-hint">Keine Termine für diesen Tag vorhanden.</p>
        }
        else
        {
            @foreach (var entry in Entries)
            {
                <div class="entry-card clickable-card" @onclick="() => OpenDetailsDialog(entry)">
                    <div class="entry-header">
                        <div>
                            <strong>@entry.Title</strong>
                            <p>@entry.StartTime.ToString(@"hh\:mm") - @entry.EndTime.ToString(@"hh\:mm") · @entry.UserDisplayName</p>
                        </div>
                        <span class="pill">@entry.EntryDate.ToString("dd.MM.yyyy")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(entry.Location))
                    {
                        <p class="entry-comment">@entry.Location</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(entry.Description))
                    {
                        <p class="entry-comment">@entry.Description</p>
                    }
                    @if (entry.CanEdit)
                    {
                        <div class="status-update">
                            <button class="ghost-button" @onclick:stopPropagation="true" @onclick="() => OpenEditDialog(entry)">Bearbeiten</button>
                            <button class="ghost-button danger" @onclick:stopPropagation="true" @onclick="() => DeleteEntryAsync(entry.CalendarEntryId)">Löschen</button>
                        </div>
                    }
                </div>
            }
        }
    </article>
</section>

@if (ShowDetailsDialog && SelectedEntry is not null)
{
    <div class="modal-backdrop" @onclick="CloseDetailsDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>@SelectedEntry.Title</h3>
                    <p>@SelectedEntry.EntryDate.ToString("dd.MM.yyyy") · @SelectedEntry.StartTime.ToString(@"hh\:mm") - @SelectedEntry.EndTime.ToString(@"hh\:mm")</p>
                </div>
                <button class="ghost-button" @onclick="CloseDetailsDialog">Schließen</button>
            </div>

            <div class="compact-details">
                <p><strong>Kalender:</strong> @SelectedEntry.UserDisplayName</p>
                @if (!string.IsNullOrWhiteSpace(SelectedEntry.Location))
                {
                    <p><strong>Ort:</strong> @SelectedEntry.Location</p>
                }
                @if (!string.IsNullOrWhiteSpace(SelectedEntry.Description))
                {
                    <p><strong>Beschreibung:</strong> @SelectedEntry.Description</p>
                }
                <p><strong>Zuletzt bearbeitet:</strong> @SelectedEntry.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
            </div>

            @if (SelectedEntry.CanEdit)
            {
                <div class="row-actions wrap-mobile modal-actions">
                    <button class="action-button" @onclick="OpenEditFromDetailsAsync">Bearbeiten</button>
                    <button class="ghost-button danger" @onclick="() => DeleteEntryFromDetailsAsync(SelectedEntry.CalendarEntryId)">Löschen</button>
                </div>
            }
        </div>
    </div>
}

@if (ShowEntryDialog)
{
    <div class="modal-backdrop" @onclick="CloseEntryDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>@(EditingEntryId.HasValue ? "Termin bearbeiten" : "Termin erstellen")</h3>
                    <p>Der Termin-Dialog bleibt bewusst kompakt und mobil gut bedienbar.</p>
                </div>
            </div>

            <div class="form-grid compact-grid">
                <label class="wide"><span>Titel</span><input @bind="Form.Title" /></label>
                <label><span>Datum</span><input type="date" value="@EntryDateText" @onchange="OnEntryDateChanged" /></label>
                <label><span>Ort</span><input @bind="Form.Location" /></label>
                <label><span>Start</span><input type="time" value="@StartTimeText" @onchange="OnStartTimeChanged" /></label>
                <label><span>Ende</span><input type="time" value="@EndTimeText" @onchange="OnEndTimeChanged" /></label>
                <label class="wide"><span>Beschreibung</span><textarea rows="4" @bind="Form.Description"></textarea></label>
            </div>

            <div class="row-actions wrap-mobile">
                <button class="action-button" @onclick="SaveEntryAsync">Termin speichern</button>
                <button class="ghost-button" @onclick="CloseEntryDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CalendarUserItem> Users { get; set; } = [];
    private List<CalendarEntryItem> Entries { get; set; } = [];
    private List<CalendarDayItem> WeekCards { get; set; } = [];
    private SaveCalendarEntryModel Form { get; set; } = new();
    private CalendarViewMode ViewMode { get; set; } = CalendarViewMode.Week;
    private int? SelectedUserId { get; set; }
    private int? EditingEntryId { get; set; }
    private bool ShowEntryDialog { get; set; }
    private bool ShowDetailsDialog { get; set; }
    private bool StatusIsWarning { get; set; }
    private string? StatusMessage { get; set; }
    private DateTime SelectedDate { get; set; } = DateTime.Today;
    private DateTime WeekStart => GetWeekStart(SelectedDate);
    private CalendarEntryItem? SelectedEntry { get; set; }

    private CalendarUserItem? SelectedUser => SelectedUserId.HasValue ? Users.FirstOrDefault(x => x.AppUserId == SelectedUserId.Value) : null;
    private bool CanEditSelectedUser => SelectedUser?.CanEdit == true;

    private string SelectedDateText => SelectedDate.ToString("yyyy-MM-dd");
    private string EntryDateText => Form.EntryDate.ToString("yyyy-MM-dd");
    private string StartTimeText => Form.StartTime.ToString(@"hh\:mm");
    private string EndTimeText => Form.EndTime.ToString(@"hh\:mm");

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsInitialized || !Auth.IsAuthenticated)
        {
            Users = [];
            Entries = [];
            WeekCards = [];
            SelectedUserId = null;
            return;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        Users = (await Offline.GetCalendarUsersAsync()).OrderByDescending(x => x.IsCurrentUser).ThenBy(x => x.DisplayName).ToList();
        if (!SelectedUserId.HasValue || Users.All(x => x.AppUserId != SelectedUserId.Value))
        {
            SelectedUserId = Users.FirstOrDefault(x => x.IsCurrentUser)?.AppUserId ?? Users.FirstOrDefault()?.AppUserId;
        }

        await ReloadEntriesAsync();
        await ReloadWeekAsync();
    }

    private async Task ReloadEntriesAsync()
    {
        if (!SelectedUserId.HasValue)
        {
            Entries = [];
            return;
        }

        Entries = (await Offline.GetCalendarEntriesAsync(SelectedUserId.Value, SelectedDate, SelectedDate))
            .OrderBy(x => x.StartTime)
            .ToList();
    }

    private async Task ReloadWeekAsync()
    {
        if (!SelectedUserId.HasValue)
        {
            WeekCards = [];
            return;
        }

        var entries = (await Offline.GetCalendarEntriesAsync(SelectedUserId.Value, WeekStart, WeekStart.AddDays(6))).ToList();
        WeekCards = Enumerable.Range(0, 7)
            .Select(offset =>
            {
                var day = WeekStart.AddDays(offset).Date;
                return new CalendarDayItem
                {
                    Date = day,
                    Entries = entries.Where(x => x.EntryDate.Date == day).OrderBy(x => x.StartTime).ToList()
                };
            })
            .ToList();
    }

    private async Task OnUserChangedAsync()
    {
        EditingEntryId = null;
        CloseEntryDialog();
        CloseDetailsDialog();
        await ReloadAsync();
    }

    private async Task ChangeViewAsync(CalendarViewMode mode)
    {
        ViewMode = mode;
        await ReloadAsync();
    }

    private async Task MoveBackwardAsync()
    {
        SelectedDate = (ViewMode == CalendarViewMode.Week ? SelectedDate.AddDays(-7) : SelectedDate.AddDays(-1)).Date;
        await ReloadAsync();
    }

    private async Task MoveForwardAsync()
    {
        SelectedDate = (ViewMode == CalendarViewMode.Week ? SelectedDate.AddDays(7) : SelectedDate.AddDays(1)).Date;
        await ReloadAsync();
    }

    private async Task GoToTodayAsync()
    {
        SelectedDate = DateTime.Today;
        await ReloadAsync();
    }

    private async Task SelectDayAsync(DateTime day)
    {
        SelectedDate = day.Date;
        await ReloadEntriesAsync();

        if (CanEditSelectedUser && ViewMode == CalendarViewMode.Day)
        {
            OpenCreateDialog(day);
        }
    }

    private void OpenCreateDialog(DateTime day)
    {
        if (!CanEditSelectedUser)
        {
            SetStatus("Du kannst nur deinen eigenen Kalender bearbeiten.", true);
            return;
        }

        EditingEntryId = null;
        Form = new SaveCalendarEntryModel
        {
            EntryDate = day.Date,
            StartTime = new TimeSpan(8, 0, 0),
            EndTime = new TimeSpan(9, 0, 0),
            Title = "",
            Description = "",
            Location = ""
        };
        ShowEntryDialog = true;
    }

    private void OpenEditDialog(CalendarEntryItem entry)
    {
        CloseDetailsDialog();
        EditingEntryId = entry.CalendarEntryId;
        Form = new SaveCalendarEntryModel
        {
            EntryDate = entry.EntryDate.Date,
            StartTime = entry.StartTime,
            EndTime = entry.EndTime,
            Title = entry.Title,
            Description = entry.Description,
            Location = entry.Location
        };
        ShowEntryDialog = true;
    }

    private void CloseEntryDialog()
    {
        ShowEntryDialog = false;
        EditingEntryId = null;
        Form = new SaveCalendarEntryModel();
    }

    private void OpenDetailsDialog(CalendarEntryItem entry)
    {
        SelectedEntry = entry;
        ShowDetailsDialog = true;
    }

    private void CloseDetailsDialog()
    {
        ShowDetailsDialog = false;
        SelectedEntry = null;
    }

    private void OnSelectedDateChanged(ChangeEventArgs args)
    {
        SelectedDate = DateTime.TryParse(args.Value?.ToString(), out var date) ? date.Date : DateTime.Today;
    }

    private void OnEntryDateChanged(ChangeEventArgs args)
    {
        Form.EntryDate = DateTime.TryParse(args.Value?.ToString(), out var date) ? date.Date : SelectedDate;
    }

    private void OnStartTimeChanged(ChangeEventArgs args)
    {
        Form.StartTime = TimeSpan.TryParse(args.Value?.ToString(), out var time) ? time : new TimeSpan(8, 0, 0);
    }

    private void OnEndTimeChanged(ChangeEventArgs args)
    {
        Form.EndTime = TimeSpan.TryParse(args.Value?.ToString(), out var time) ? time : new TimeSpan(9, 0, 0);
    }

    private async Task SaveEntryAsync()
    {
        if (!CanEditSelectedUser)
        {
            SetStatus("Du kannst nur deinen eigenen Kalender bearbeiten.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(Form.Title))
        {
            SetStatus("Bitte einen Titel eingeben.", true);
            return;
        }

        if (Form.EndTime <= Form.StartTime)
        {
            SetStatus("Die Endzeit muss nach der Startzeit liegen.", true);
            return;
        }

        var saved = await Api.SaveCalendarEntryAsync(Form, EditingEntryId);
        SelectedDate = saved.EntryDate.Date;
        CloseEntryDialog();
        CloseDetailsDialog();
        SetStatus("Termin gespeichert.", false);
        await ReloadAsync();
    }

    private async Task DeleteEntryAsync(int calendarEntryId)
    {
        await Api.DeleteCalendarEntryAsync(calendarEntryId);
        CloseDetailsDialog();
        SetStatus("Termin gelöscht.", false);
        await ReloadAsync();
    }

    private Task OpenEditFromDetailsAsync()
    {
        if (SelectedEntry is not null)
        {
            OpenEditDialog(SelectedEntry);
        }

        return Task.CompletedTask;
    }

    private Task DeleteEntryFromDetailsAsync(int calendarEntryId)
        => DeleteEntryAsync(calendarEntryId);

    private void SetStatus(string message, bool isWarning)
    {
        StatusMessage = message;
        StatusIsWarning = isWarning;
    }

    private static DateTime GetWeekStart(DateTime date)
    {
        var diff = ((int)date.DayOfWeek + 6) % 7;
        return date.Date.AddDays(-diff);
    }

    private sealed class CalendarDayItem
    {
        public DateTime Date { get; set; }
        public List<CalendarEntryItem> Entries { get; set; } = [];
    }

    private enum CalendarViewMode
    {
        Day,
        Week
    }
}
