@page "/customers"
@inject BackendApiClient Api
@inject WebAuthSession Auth

<PageTitle>Kunden</PageTitle>

<section class="page-section">
    <div class="section-heading">
        <div>
            <h2>Kunden</h2>
            <p>Kundenstammdaten pflegen und nur zum ausgewählten Kunden die wichtigen Informationen kompakt ansehen.</p>
        </div>
        <div class="row-actions wrap-mobile">
            <button class="action-button" @onclick="OpenCreateCustomerDialog">Kunde anlegen</button>
            <button class="action-button secondary" @onclick="LoadAsync">Aktualisieren</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="inline-status">@StatusMessage</div>
    }

    <div class="split-grid two-columns">
        <article class="list-card">
            <div class="table-header compact">
                <h3>Kundenliste</h3>
                <span>@CustomerItems.Count Einträge</span>
            </div>

            @foreach (var customer in CustomerItems)
            {
                <button type="button" class="list-row stacked-mobile selectable-list-row @(SelectedCustomer?.CustomerId == customer.CustomerId ? "selected-row" : string.Empty)" @onclick="() => SelectCustomerAsync(customer.CustomerId)">
                    <div>
                        <strong>@customer.Name</strong>
                        <p>@BuildAddress(customer)</p>
                    </div>
                    <div class="row-actions wrap-mobile">
                        <span class="pill">@customer.ProjectCount Projekt(e)</span>
                        <span class="pill">@customer.OpenWorkItems offene Zeiten</span>
                    </div>
                </button>
            }
        </article>

        <article class="feature-card">
            @if (SelectedCustomer is null)
            {
                <p class="empty-hint">Bitte zuerst einen Kunden auswählen.</p>
            }
            else
            {
                <div class="table-header compact">
                    <div>
                        <h3>@SelectedCustomer.Name</h3>
                        <p>@BuildAddress(SelectedCustomer)</p>
                    </div>
                    <div class="row-actions wrap-mobile">
                        <button class="ghost-button" @onclick="OpenEditCustomerDialog">Bearbeiten</button>
                        <button class="ghost-button danger" @onclick="DeleteSelectedCustomerAsync">Löschen</button>
                    </div>
                </div>

                <div class="compact-info-grid">
                    <div class="compact-info-card">
                        <span>E-Mail</span>
                        <strong>@DisplayOrFallback(SelectedCustomer.EmailAddress)</strong>
                    </div>
                    <div class="compact-info-card">
                        <span>Telefon</span>
                        <strong>@DisplayOrFallback(SelectedCustomer.PhoneNumber)</strong>
                    </div>
                    <div class="compact-info-card">
                        <span>Standard-Zuschlag</span>
                        <strong>@SelectedCustomer.DefaultMarkupPercent.ToString("0.##") %</strong>
                    </div>
                    <div class="compact-info-card">
                        <span>Aktive Projekte</span>
                        <strong>@CustomerProjects.Count(x => string.Equals(x.ProjectStatus, "Active", StringComparison.OrdinalIgnoreCase))</strong>
                    </div>
                </div>

                <div class="detail-list-block">
                    <div class="table-header compact">
                        <h3>Projekte des Kunden</h3>
                        <span>@CustomerProjects.Count Einträge</span>
                    </div>
                    @if (CustomerProjects.Count == 0)
                    {
                        <p class="empty-hint">Für diesen Kunden sind noch keine Projekte vorhanden.</p>
                    }
                    else
                    {
                        @foreach (var project in CustomerProjects)
                        {
                            <div class="list-row stacked-mobile">
                                <div>
                                    <strong>@project.Name</strong>
                                    <p>Status: @ProjectStatusLabel(project.ProjectStatus)</p>
                                </div>
                                <div class="row-actions wrap-mobile">
                                    <span class="pill">@project.LoggedHours.ToString("0.##") h</span>
                                    <span class="pill">@project.OpenWorkItems offene Zeiten</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </article>
    </div>
</section>

@if (ShowCustomerDialog)
{
    <div class="modal-backdrop" @onclick="CloseCustomerDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>@(EditingCustomerId.HasValue ? "Kunde bearbeiten" : "Kunde anlegen")</h3>
                    <p>Kundendaten werden wie in der WPF in einem eigenen Dialog gepflegt.</p>
                </div>
            </div>

            <div class="form-grid compact-grid">
                <label><span>Vorname</span><input @bind="CustomerForm.FirstName" /></label>
                <label><span>Nachname</span><input @bind="CustomerForm.LastName" /></label>
                <label><span>Straße</span><input @bind="CustomerForm.Street" /></label>
                <label><span>Hausnummer</span><input @bind="CustomerForm.HouseNumber" /></label>
                <label><span>Postleitzahl</span><input @bind="CustomerForm.PostalCode" /></label>
                <label><span>Ort</span><input @bind="CustomerForm.City" /></label>
                <label><span>E-Mail-Adresse</span><input @bind="CustomerForm.EmailAddress" /></label>
                <label><span>Telefonnummer</span><input @bind="CustomerForm.PhoneNumber" /></label>
                <label><span>Standard-Zuschlag (%)</span><input type="number" step="0.01" @bind="CustomerForm.DefaultMarkupPercent" /></label>
            </div>

            <div class="row-actions wrap-mobile">
                <button class="action-button" @onclick="SaveCustomerAsync">Speichern</button>
                <button class="ghost-button" @onclick="CloseCustomerDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CustomerItem> CustomerItems { get; set; } = [];
    private List<ProjectItem> CustomerProjects { get; set; } = [];
    private SaveCustomerModel CustomerForm { get; set; } = new();
    private CustomerItem? SelectedCustomer { get; set; }
    private int? EditingCustomerId { get; set; }
    private bool ShowCustomerDialog { get; set; }
    private string? StatusMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsInitialized || !Auth.IsAuthenticated)
        {
            CustomerItems = [];
            CustomerProjects = [];
            SelectedCustomer = null;
            EditingCustomerId = null;
            ShowCustomerDialog = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        CustomerItems = (await Api.GetCustomersAsync()).OrderBy(x => x.Name).ToList();
        if (SelectedCustomer is null && CustomerItems.Count > 0)
        {
            SelectedCustomer = CustomerItems[0];
        }
        else if (SelectedCustomer is not null)
        {
            SelectedCustomer = CustomerItems.FirstOrDefault(x => x.CustomerId == SelectedCustomer.CustomerId) ?? CustomerItems.FirstOrDefault();
        }

        await LoadSelectedCustomerProjectsAsync();
    }

    private async Task SelectCustomerAsync(int customerId)
    {
        SelectedCustomer = CustomerItems.FirstOrDefault(x => x.CustomerId == customerId);
        await LoadSelectedCustomerProjectsAsync();
    }

    private async Task LoadSelectedCustomerProjectsAsync()
    {
        CustomerProjects = SelectedCustomer is null
            ? []
            : (await Api.GetProjectsAsync(SelectedCustomer.CustomerId, includeInactive: true)).OrderBy(x => x.Name).ToList();
    }

    private void OpenCreateCustomerDialog()
    {
        EditingCustomerId = null;
        CustomerForm = new SaveCustomerModel();
        ShowCustomerDialog = true;
    }

    private void OpenEditCustomerDialog()
    {
        if (SelectedCustomer is null)
        {
            return;
        }

        EditingCustomerId = SelectedCustomer.CustomerId;
        CustomerForm = new SaveCustomerModel
        {
            Name = SelectedCustomer.Name,
            FirstName = SelectedCustomer.FirstName,
            LastName = SelectedCustomer.LastName,
            Street = SelectedCustomer.Street,
            HouseNumber = SelectedCustomer.HouseNumber,
            PostalCode = SelectedCustomer.PostalCode,
            City = SelectedCustomer.City,
            EmailAddress = SelectedCustomer.EmailAddress,
            PhoneNumber = SelectedCustomer.PhoneNumber,
            DefaultMarkupPercent = SelectedCustomer.DefaultMarkupPercent
        };
        ShowCustomerDialog = true;
    }

    private void CloseCustomerDialog()
    {
        ShowCustomerDialog = false;
        EditingCustomerId = null;
    }

    private async Task SaveCustomerAsync()
    {
        var displayName = BuildCustomerDisplayName();
        if (string.IsNullOrWhiteSpace(displayName))
        {
            StatusMessage = "Bitte mindestens Vorname oder Nachname angeben.";
            return;
        }

        try
        {
            CustomerForm.Name = displayName;
            var saved = await Api.SaveCustomerAsync(CustomerForm, EditingCustomerId);
            SelectedCustomer = saved;
            CloseCustomerDialog();
            StatusMessage = $"Kunde {saved.Name} gespeichert.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
        }
    }

    private async Task DeleteSelectedCustomerAsync()
    {
        if (SelectedCustomer is null)
        {
            return;
        }

        await Api.DeleteCustomerAsync(SelectedCustomer.CustomerId);
        StatusMessage = "Kunde gelöscht.";
        SelectedCustomer = null;
        await LoadAsync();
    }

    private string BuildCustomerDisplayName()
    {
        var parts = new[] { CustomerForm.FirstName?.Trim(), CustomerForm.LastName?.Trim() }
            .Where(x => !string.IsNullOrWhiteSpace(x));
        return string.Join(" ", parts).Trim();
    }

    private static string BuildAddress(CustomerItem customer)
    {
        var left = string.Join(" ", new[] { customer.Street, customer.HouseNumber }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        var right = string.Join(" ", new[] { customer.PostalCode, customer.City }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        return string.Join(", ", new[] { left, right }.Where(x => !string.IsNullOrWhiteSpace(x)));
    }

    private static string DisplayOrFallback(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Nicht hinterlegt" : value;

    private static string ProjectStatusLabel(string? value)
        => value switch
        {
            "Paused" => "Pausiert",
            "Ended" => "Beendet",
            _ => "Aktiv"
        };
}
