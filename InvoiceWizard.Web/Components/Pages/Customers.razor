@page "/customers"
@inject BackendApiClient Api
@inject WebAuthSession Auth

<PageTitle>Kunden & Projekte</PageTitle>

<section class="page-section">
    <div class="section-heading">
        <div>
            <h2>Kunden & Projekte</h2>
            <p>Kundenstammdaten mobil pflegen, Projekte ansehen und bei Bedarf direkt neue Projekte anlegen.</p>
        </div>
        <button class="action-button secondary" @onclick="LoadAsync">Neu laden</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="inline-status">@StatusMessage</div>
    }

    <div class="split-grid two-columns">
        <article class="feature-card">
            <div class="table-header compact">
                <h3>Kundendaten</h3>
                @if (EditingCustomerId.HasValue)
                {
                    <span class="pill warning">Bearbeitung</span>
                }
            </div>

            <div class="form-grid">
                <label><span>Vorname</span><input @bind="CustomerForm.FirstName" /></label>
                <label><span>Nachname</span><input @bind="CustomerForm.LastName" /></label>
                <label><span>Strasse</span><input @bind="CustomerForm.Street" /></label>
                <label><span>Hausnummer</span><input @bind="CustomerForm.HouseNumber" /></label>
                <label><span>Postleitzahl</span><input @bind="CustomerForm.PostalCode" /></label>
                <label><span>Ort</span><input @bind="CustomerForm.City" /></label>
                <label><span>E-Mail-Adresse</span><input @bind="CustomerForm.EmailAddress" /></label>
                <label><span>Telefonnummer</span><input @bind="CustomerForm.PhoneNumber" /></label>
                <label><span>Standard-Zuschlag (%)</span><input type="number" step="0.01" @bind="CustomerForm.DefaultMarkupPercent" /></label>
            </div>

            <div class="status-update">
                <button class="action-button" @onclick="SaveCustomerAsync">@(EditingCustomerId.HasValue ? "Kunde aktualisieren" : "Neuen Kunden speichern")</button>
                <button class="ghost-button" @onclick="ClearCustomerForm">Formular leeren</button>
            </div>
        </article>

        <article class="feature-card">
            <h3>Projekt fuer Kunden anlegen</h3>
            <label>
                <span>Kunde</span>
                <select @bind="SelectedCustomerId">
                    <option value="">Bitte waehlen</option>
                    @foreach (var customer in CustomerItems)
                    {
                        <option value="@customer.CustomerId">@customer.Name</option>
                    }
                </select>
            </label>
            <label><span>Projektname</span><input @bind="ProjectForm.Name" /></label>
            <button class="action-button" @onclick="SaveProjectAsync" disabled="@(!SelectedCustomerId.HasValue)">Projekt speichern</button>

            <div class="compact-details">
                <h4>Kurzueberblick</h4>
                <div class="inline-metrics">
                    <div><span>Kunden</span><strong>@CustomerItems.Count</strong></div>
                    <div><span>Projekte</span><strong>@Projects.Count</strong></div>
                    <div><span>Offene Zeiten</span><strong>@CustomerItems.Sum(x => x.OpenWorkItems)</strong></div>
                </div>
            </div>
        </article>
    </div>

    <div class="list-card">
        <div class="table-header"><h3>Kunden</h3><span>@CustomerItems.Count Eintraege</span></div>
        @foreach (var customer in CustomerItems)
        {
            <div class="list-row stacked-mobile">
                <div>
                    <strong>@customer.Name</strong>
                    <p>@BuildAddress(customer)</p>
                    <p>@customer.ProjectCount Projekt(e), @customer.OpenWorkItems offene Arbeitszeitposition(en)</p>
                </div>
                <div class="row-actions wrap-mobile">
                    @if (!string.IsNullOrWhiteSpace(customer.EmailAddress))
                    {
                        <span class="pill">@customer.EmailAddress</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(customer.PhoneNumber))
                    {
                        <span class="pill">@customer.PhoneNumber</span>
                    }
                    <span class="pill">@customer.DefaultMarkupPercent.ToString("0.##") %</span>
                    <button class="ghost-button" @onclick="() => SelectCustomer(customer)">Bearbeiten</button>
                    <button class="ghost-button danger" @onclick="() => DeleteCustomerAsync(customer.CustomerId)">Loeschen</button>
                </div>
            </div>
        }
    </div>

    <div class="list-card">
        <div class="table-header"><h3>Projekte</h3><span>@Projects.Count Eintraege</span></div>
        @foreach (var project in Projects)
        {
            <div class="list-row stacked-mobile">
                <div>
                    <strong>@project.Name</strong>
                    <p>@project.CustomerName</p>
                    <p>@project.LoggedHours.ToString("0.##") h erfasst · @project.OpenWorkItems offene Position(en)</p>
                </div>
                <div class="row-actions wrap-mobile">
                    <button class="ghost-button danger" @onclick="() => DeleteProjectAsync(project.ProjectId)">Loeschen</button>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private List<CustomerItem> CustomerItems { get; set; } = [];
    private List<ProjectItem> Projects { get; set; } = [];
    private SaveCustomerModel CustomerForm { get; set; } = new();
    private SaveProjectModel ProjectForm { get; set; } = new();
    private int? EditingCustomerId { get; set; }
    private int? SelectedCustomerId { get; set; }
    private string? StatusMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsInitialized || !Auth.IsAuthenticated)
        {
            CustomerItems = [];
            Projects = [];
            EditingCustomerId = null;
            SelectedCustomerId = null;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        CustomerItems = (await Api.GetCustomersAsync()).OrderBy(x => x.Name).ToList();
        Projects = (await Api.GetProjectsAsync()).OrderBy(x => x.CustomerName).ThenBy(x => x.Name).ToList();
        if (!SelectedCustomerId.HasValue && CustomerItems.Count > 0)
        {
            SelectedCustomerId = CustomerItems[0].CustomerId;
        }
    }

    private void SelectCustomer(CustomerItem customer)
    {
        EditingCustomerId = customer.CustomerId;
        SelectedCustomerId = customer.CustomerId;
        CustomerForm = new SaveCustomerModel
        {
            Name = customer.Name,
            FirstName = customer.FirstName,
            LastName = customer.LastName,
            Street = customer.Street,
            HouseNumber = customer.HouseNumber,
            PostalCode = customer.PostalCode,
            City = customer.City,
            EmailAddress = customer.EmailAddress,
            PhoneNumber = customer.PhoneNumber,
            DefaultMarkupPercent = customer.DefaultMarkupPercent
        };
        StatusMessage = $"Kunde {customer.Name} zur Bearbeitung geladen.";
    }

    private async Task SaveCustomerAsync()
    {
        var displayName = BuildCustomerDisplayName();
        if (string.IsNullOrWhiteSpace(displayName))
        {
            StatusMessage = "Bitte mindestens Vorname oder Nachname angeben.";
            return;
        }

        CustomerForm.Name = displayName;
        var saved = await Api.SaveCustomerAsync(CustomerForm, EditingCustomerId);
        EditingCustomerId = null;
        SelectedCustomerId = saved.CustomerId;
        CustomerForm = new SaveCustomerModel();
        StatusMessage = $"Kunde {saved.Name} gespeichert.";
        await LoadAsync();
    }

    private async Task SaveProjectAsync()
    {
        if (!SelectedCustomerId.HasValue || string.IsNullOrWhiteSpace(ProjectForm.Name))
        {
            StatusMessage = "Bitte Kunde und Projektname angeben.";
            return;
        }

        var project = await Api.CreateProjectAsync(SelectedCustomerId.Value, ProjectForm);
        ProjectForm = new SaveProjectModel();
        StatusMessage = $"Projekt {project.Name} gespeichert.";
        await LoadAsync();
    }

    private async Task DeleteCustomerAsync(int customerId)
    {
        await Api.DeleteCustomerAsync(customerId);
        if (EditingCustomerId == customerId)
        {
            ClearCustomerForm();
        }

        StatusMessage = "Kunde geloescht.";
        await LoadAsync();
    }

    private async Task DeleteProjectAsync(int projectId)
    {
        await Api.DeleteProjectAsync(projectId);
        StatusMessage = "Projekt geloescht.";
        await LoadAsync();
    }

    private void ClearCustomerForm()
    {
        EditingCustomerId = null;
        CustomerForm = new SaveCustomerModel();
        StatusMessage = "Kundenformular geleert.";
    }

    private string BuildCustomerDisplayName()
    {
        var parts = new[] { CustomerForm.FirstName?.Trim(), CustomerForm.LastName?.Trim() }
            .Where(x => !string.IsNullOrWhiteSpace(x));
        return string.Join(" ", parts).Trim();
    }

    private static string BuildAddress(CustomerItem customer)
    {
        var left = string.Join(" ", new[] { customer.Street, customer.HouseNumber }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        var right = string.Join(" ", new[] { customer.PostalCode, customer.City }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        return string.Join(", ", new[] { left, right }.Where(x => !string.IsNullOrWhiteSpace(x)));
    }
}


