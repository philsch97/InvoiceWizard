@page "/worktime"
@inject BackendApiClient Api
@inject WebAuthSession Auth

<PageTitle>Arbeitszeit</PageTitle>

<section class="page-section">
    <div class="section-heading">
        <div>
            <h2>Arbeitszeit</h2>
            <p>Zeiten mobil erfassen, jetzt direkt als Start, Ende oder Pause uebernehmen und Positionen spaeter fakturieren.</p>
        </div>
        <button class="action-button secondary" @onclick="ReloadAsync">Aktualisieren</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="inline-status @(StatusIsWarning ? "warning" : string.Empty)">@StatusMessage</div>
    }

    <div class="split-grid">
        <article class="feature-card">
            <h3>Neuer Eintrag</h3>
            <div class="form-grid">
                <label>
                    <span>Kunde</span>
                    <select @bind="Form.CustomerId" @bind:after="LoadProjectsForSelectedCustomerAsync">
                        <option value="0">Bitte waehlen</option>
                        @foreach (var customer in Customers)
                        {
                            <option value="@customer.CustomerId">@customer.Name</option>
                        }
                    </select>
                </label>
                <label>
                    <span>Projekt</span>
                    <select @bind="Form.ProjectId">
                        <option value="">Ohne Projekt</option>
                        @foreach (var project in AvailableProjects)
                        {
                            <option value="@project.ProjectId">@project.Name</option>
                        }
                    </select>
                </label>
                <label><span>Datum</span><input type="date" value="@WorkDateText" @onchange="OnWorkDateChanged" /></label>
                <label>
                    <span>Beginn</span>
                    <div class="field-with-action">
                        <input type="time" value="@StartTimeText" @onchange="OnStartTimeChanged" />
                        <button type="button" class="ghost-button small" @onclick="SetStartNow">Jetzt</button>
                    </div>
                </label>
                <label>
                    <span>Ende</span>
                    <div class="field-with-action">
                        <input type="time" value="@EndTimeText" @onchange="OnEndTimeChanged" />
                        <button type="button" class="ghost-button small" @onclick="SetEndNow">Jetzt</button>
                    </div>
                </label>
                <label>
                    <span>Pause (Min.)</span>
                    <div class="field-with-action">
                        <input type="number" @bind="Form.BreakMinutes" />
                        <button type="button" class="ghost-button small" @onclick="TogglePauseNow">@(PauseStartedAt.HasValue ? "Pause beenden" : "Pause jetzt")</button>
                    </div>
                </label>
                <label><span>Stundensatz</span><input type="number" step="0.01" @bind="Form.HourlyRate" /></label>
                <label><span>Anfahrt (km)</span><input type="number" step="0.01" @bind="Form.TravelKilometers" /></label>
                <label><span>Preis / km</span><input type="number" step="0.01" @bind="Form.TravelRatePerKilometer" /></label>
                <label class="wide"><span>Beschreibung</span><input @bind="Form.Description" /></label>
                <label class="wide"><span>Kommentar</span><textarea rows="3" @bind="Form.Comment"></textarea></label>
            </div>

            @if (RequireCommentForSave && string.IsNullOrWhiteSpace(Form.Comment))
            {
                <div class="inline-status warning">Bitte nach dem Setzen der Endzeit kurz einen Kommentar eingeben, bevor du speicherst.</div>
            }

            @if (PauseStartedAt.HasValue)
            {
                <div class="inline-status">Pause laeuft seit @PauseStartedAt.Value.ToString(@"hh\:mm"). Beim erneuten Tippen werden die Minuten automatisch eingetragen.</div>
            }

            <button class="action-button" @onclick="SaveWorkTimeAsync">Speichern</button>
        </article>

        <article class="feature-card">
            <h3>Filter</h3>
            <label>
                <span>Kunde</span>
                <select @bind="FilterCustomerId" @bind:after="HandleFilterCustomerChangedAsync">
                    <option value="">Alle Kunden</option>
                    @foreach (var customer in Customers)
                    {
                        <option value="@customer.CustomerId">@customer.Name</option>
                    }
                </select>
            </label>
            <label>
                <span>Projekt</span>
                <select @bind="FilterProjectId" @bind:after="ReloadAsync">
                    <option value="">Alle Projekte</option>
                    @foreach (var project in FilterProjects)
                    {
                        <option value="@project.ProjectId">@project.Name</option>
                    }
                </select>
            </label>
            <div class="inline-metrics stats-inline-grid">
                <div><span>Eintraege</span><strong>@Entries.Count</strong></div>
                <div><span>Stunden</span><strong>@Entries.Sum(x => x.HoursWorked).ToString("0.##")</strong></div>
                <div><span>Kilometer</span><strong>@Entries.Sum(x => x.TravelKilometers).ToString("0.##")</strong></div>
            </div>
        </article>
    </div>

    <div class="list-card">
        <div class="table-header"><h3>Zeiteintraege</h3><span>@Entries.Count Eintraege</span></div>
        @foreach (var entry in Entries)
        {
            <div class="entry-card">
                <div class="entry-header">
                    <div><strong>@entry.Description</strong><p>@entry.CustomerName · @(entry.ProjectName ?? "Ohne Projekt")</p></div>
                    <span class="pill @(entry.IsPaid ? "success" : string.IsNullOrWhiteSpace(entry.CustomerInvoiceNumber) ? string.Empty : "warning")">@(entry.IsPaid ? "Bezahlt" : string.IsNullOrWhiteSpace(entry.CustomerInvoiceNumber) ? "Offen" : "Fakturiert")</span>
                </div>
                <div class="entry-meta">
                    <span>@entry.WorkDate.ToString("dd.MM.yyyy")</span>
                    <span>@entry.StartTime.ToString(@"hh\:mm") - @entry.EndTime.ToString(@"hh\:mm")</span>
                    <span>@entry.HoursWorked.ToString("0.##") h</span>
                    <span>@entry.TravelKilometers.ToString("0.##") km</span>
                    <span>@entry.LineTotal.ToString("0.00") EUR</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(entry.Comment))
                {
                    <p class="entry-comment">@entry.Comment</p>
                }
                <div class="status-update">
                    <input placeholder="Rechnungsnr." @bind="InvoiceNumbers[entry.WorkTimeEntryId]" />
                    <button class="ghost-button" @onclick="() => MarkInvoicedAsync(entry.WorkTimeEntryId)">Fakturiert</button>
                    <button class="ghost-button" @onclick="() => MarkPaidAsync(entry.WorkTimeEntryId)">Bezahlt</button>
                    <button class="ghost-button danger" @onclick="() => DeleteAsync(entry.WorkTimeEntryId)">Loeschen</button>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private List<CustomerItem> Customers { get; set; } = [];
    private List<ProjectItem> AvailableProjects { get; set; } = [];
    private List<ProjectItem> FilterProjects { get; set; } = [];
    private List<WorkTimeItem> Entries { get; set; } = [];
    private SaveWorkTimeModel Form { get; set; } = new();
    private Dictionary<int, string?> InvoiceNumbers { get; set; } = [];
    private int? FilterCustomerId { get; set; }
    private int? FilterProjectId { get; set; }
    private TimeSpan? PauseStartedAt { get; set; }
    private bool RequireCommentForSave { get; set; }
    private bool StatusIsWarning { get; set; }
    private string? StatusMessage { get; set; }

    private string WorkDateText => Form.WorkDate.ToString("yyyy-MM-dd");
    private string StartTimeText => Form.StartTime.ToString(@"hh\:mm");
    private string EndTimeText => Form.EndTime.ToString(@"hh\:mm");

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsInitialized || !Auth.IsAuthenticated)
        {
            Customers = [];
            AvailableProjects = [];
            FilterProjects = [];
            Entries = [];
            FilterCustomerId = null;
            FilterProjectId = null;
            return;
        }

        Customers = (await Api.GetCustomersAsync()).ToList();
        if (Customers.Count == 0)
        {
            AvailableProjects = [];
            FilterProjects = [];
            Entries = [];
            Form.CustomerId = 0;
            FilterCustomerId = null;
            FilterProjectId = null;
            return;
        }

        if (Form.CustomerId <= 0 || Customers.All(x => x.CustomerId != Form.CustomerId))
        {
            Form.CustomerId = Customers[0].CustomerId;
        }

        if (!FilterCustomerId.HasValue || Customers.All(x => x.CustomerId != FilterCustomerId.Value))
        {
            FilterCustomerId = Customers[0].CustomerId;
        }

        await LoadProjectsForSelectedCustomerAsync();
        await HandleFilterCustomerChangedAsync();
    }

    private async Task LoadProjectsForSelectedCustomerAsync()
    {
        AvailableProjects = Form.CustomerId > 0 ? (await Api.GetProjectsAsync(Form.CustomerId)).ToList() : [];
    }

    private async Task HandleFilterCustomerChangedAsync()
    {
        FilterProjects = FilterCustomerId.HasValue ? (await Api.GetProjectsAsync(FilterCustomerId.Value)).ToList() : [];
        if (FilterProjectId.HasValue && FilterProjects.All(x => x.ProjectId != FilterProjectId.Value))
        {
            FilterProjectId = null;
        }

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        Entries = (await Api.GetWorkTimesAsync(FilterCustomerId, FilterProjectId)).ToList();
        InvoiceNumbers = Entries.ToDictionary(x => x.WorkTimeEntryId, x => x.CustomerInvoiceNumber);
    }

    private void OnWorkDateChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        Form.WorkDate = DateTime.TryParse(value, out var result) ? result.Date : DateTime.Today;
    }

    private void OnStartTimeChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        Form.StartTime = TimeSpan.TryParse(value, out var result) ? result : new TimeSpan(8, 0, 0);
    }

    private void OnEndTimeChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        Form.EndTime = TimeSpan.TryParse(value, out var result) ? result : new TimeSpan(16, 30, 0);
    }

    private async Task SaveWorkTimeAsync()
    {
        if (Form.CustomerId <= 0)
        {
            SetStatus("Bitte einen Kunden auswaehlen.", true);
            return;
        }

        if (RequireCommentForSave && string.IsNullOrWhiteSpace(Form.Comment))
        {
            SetStatus("Bitte nach dem Setzen der Endzeit noch einen Kommentar eingeben.", true);
            return;
        }

        PauseStartedAt = null;
        await Api.CreateWorkTimeAsync(Form);
        Form.Comment = string.Empty;
        Form.Description = "Arbeitszeit";
        RequireCommentForSave = false;
        SetStatus("Zeiteintrag gespeichert.", false);
        await ReloadAsync();
    }

    private Task SetStartNow()
    {
        Form.StartTime = DateTime.Now.TimeOfDay;
        if (Form.EndTime <= Form.StartTime)
        {
            Form.EndTime = Form.StartTime.Add(TimeSpan.FromHours(1));
        }

        SetStatus($"Startzeit auf {Form.StartTime:hh\\:mm} gesetzt.", false);
        return Task.CompletedTask;
    }

    private Task SetEndNow()
    {
        Form.EndTime = DateTime.Now.TimeOfDay;
        if (Form.EndTime <= Form.StartTime)
        {
            Form.EndTime = Form.StartTime.Add(TimeSpan.FromMinutes(15));
        }

        RequireCommentForSave = true;
        SetStatus($"Endzeit auf {Form.EndTime:hh\\:mm} gesetzt. Bitte noch einen Kommentar eintragen.", true);
        return Task.CompletedTask;
    }

    private Task TogglePauseNow()
    {
        var now = DateTime.Now.TimeOfDay;
        if (!PauseStartedAt.HasValue)
        {
            PauseStartedAt = now;
            SetStatus($"Pause gestartet um {now:hh\\:mm}.", false);
            return Task.CompletedTask;
        }

        var minutes = now >= PauseStartedAt.Value ? (int)Math.Round((now - PauseStartedAt.Value).TotalMinutes) : 0;
        Form.BreakMinutes += Math.Max(minutes, 0);
        PauseStartedAt = null;
        SetStatus($"Pause uebernommen. Aktuelle Pausenzeit: {Form.BreakMinutes} Minuten.", false);
        return Task.CompletedTask;
    }

    private async Task MarkInvoicedAsync(int id)
    {
        await Api.UpdateWorkTimeStatusAsync(id, new UpdateWorkTimeStatusModel { CustomerInvoiceNumber = InvoiceNumbers.GetValueOrDefault(id), MarkInvoiced = true });
        SetStatus("Eintrag als fakturiert markiert.", false);
        await ReloadAsync();
    }

    private async Task MarkPaidAsync(int id)
    {
        await Api.UpdateWorkTimeStatusAsync(id, new UpdateWorkTimeStatusModel { CustomerInvoiceNumber = InvoiceNumbers.GetValueOrDefault(id), MarkPaid = true });
        SetStatus("Eintrag als bezahlt markiert.", false);
        await ReloadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        await Api.DeleteWorkTimeAsync(id);
        SetStatus("Eintrag geloescht.", false);
        await ReloadAsync();
    }

    private void SetStatus(string message, bool isWarning)
    {
        StatusMessage = message;
        StatusIsWarning = isWarning;
    }
}
