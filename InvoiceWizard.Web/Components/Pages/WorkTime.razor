@page "/worktime"
@inject BackendApiClient Api
@inject WebAuthSession Auth
@inject WebUiSelectionState UiState
@inject WebOfflineDataService Offline

<PageTitle>Arbeitszeit</PageTitle>

<section class="page-section">
    <div class="section-heading">
        <div>
            <h2>Arbeitszeit</h2>
            <p>Starte Projektzeiten direkt wie an einer Stechuhr oder trage Zeiten nachträglich manuell ein.</p>
        </div>
        <div class="row-actions wrap-mobile">
            <button class="action-button" @onclick="OpenStartDialog" disabled="@(ActiveClock is not null)">Projekt stechen</button>
            <button class="action-button" @onclick="OpenCreateEntryDialog">Arbeitszeit nachtragen</button>
            <button class="action-button secondary" @onclick="ReloadAsync">Aktualisieren</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="inline-status @(StatusIsWarning ? "warning" : string.Empty)">@StatusMessage</div>
    }

    <div class="split-grid two-columns">
        <article class="feature-card">
            <div class="table-header compact">
                <div>
                    <h3>Projekt stechen</h3>
                    <p>Projektzeiten direkt starten, pausieren und beenden.</p>
                </div>
                @if (ActiveClock is not null)
                {
                    <span class="pill @(ActiveClock.PauseStartedAtUtc.HasValue ? "warning" : "success")">
                        @(ActiveClock.PauseStartedAtUtc.HasValue ? "Pause läuft" : "Aktiv")
                    </span>
                }
            </div>

            @if (ActiveClock is null)
            {
                <p class="empty-hint">Aktuell läuft keine Projektzeit. Starte eine neue Zeit über den Button oben.</p>
            }
            else
            {
                <div class="active-clock-card">
                    <strong>@ActiveClock.CustomerName · @(ActiveClock.ProjectName ?? "Ohne Projekt")</strong>
                    <p>Gestartet um @ActiveClock.StartTime.ToString(@"hh\:mm") Uhr · @ActiveClock.WorkDate.ToString("dd.MM.yyyy")</p>
                    <p>@ActiveClock.Description</p>
                    <div class="entry-meta">
                        <span>Pause: @ActiveClock.BreakMinutes min</span>
                        @if (ActiveClock.PauseStartedAtUtc.HasValue)
                        {
                            <span>Pausenstart: @ActiveClock.PauseStartedAtUtc.Value.ToLocalTime().ToString("HH:mm")</span>
                        }
                    </div>
                </div>

                <div class="row-actions wrap-mobile">
                    <button class="action-button secondary" @onclick="TogglePauseAsync">@(ActiveClock.PauseStartedAtUtc.HasValue ? "Pause beenden" : "Pause starten")</button>
                    <button class="action-button" @onclick="OpenStopDialog">Projektstopp</button>
                </div>
            }
        </article>

        <article class="feature-card">
            <h3>Filter</h3>
            <div class="form-grid">
                <label>
                    <span>Kunde</span>
                    <select @bind="FilterCustomerId" @bind:after="HandleFilterCustomerChangedAsync">
                        <option value="">Alle Kunden</option>
                        @foreach (var customer in Customers)
                        {
                            <option value="@customer.CustomerId">@customer.Name</option>
                        }
                    </select>
                </label>
                <label>
                    <span>Projekt</span>
                    <select @bind="FilterProjectId" @bind:after="ReloadEntriesAsync">
                        <option value="">Alle Projekte</option>
                        @foreach (var project in FilterProjects)
                        {
                            <option value="@project.ProjectId">@project.Name</option>
                        }
                    </select>
                </label>
            </div>

            <div class="inline-metrics stats-inline-grid">
                <div><span>Einträge</span><strong>@Entries.Count</strong></div>
                <div><span>Stunden</span><strong>@Entries.Sum(x => x.HoursWorked).ToString("0.##")</strong></div>
                <div><span>Kilometer</span><strong>@Entries.Sum(x => x.TravelKilometers).ToString("0.##")</strong></div>
            </div>
        </article>
    </div>

    <div class="list-card">
        <div class="table-header">
            <h3>Zeiteinträge</h3>
            <span>@Entries.Count Einträge</span>
        </div>
        @if (Entries.Count == 0)
        {
            <p class="empty-hint">Noch keine Arbeitszeiten gefunden.</p>
        }
        else
        {
            @foreach (var entry in Entries)
            {
                <div class="entry-card">
                    <div class="entry-header">
                        <div>
                            <strong>@entry.Description</strong>
                            <p>@entry.CustomerName · @(entry.ProjectName ?? "Ohne Projekt")</p>
                        </div>
                        <span class="pill @(entry.IsClockActive ? "success" : entry.IsPaid ? "success" : string.IsNullOrWhiteSpace(entry.CustomerInvoiceNumber) ? string.Empty : "warning")">
                            @(entry.IsClockActive ? "Läuft" : entry.IsPaid ? "Bezahlt" : string.IsNullOrWhiteSpace(entry.CustomerInvoiceNumber) ? "Offen" : "Fakturiert")
                        </span>
                    </div>
                    <div class="entry-meta">
                        <span>@entry.WorkDate.ToString("dd.MM.yyyy")</span>
                        <span>@entry.StartTime.ToString(@"hh\:mm") - @entry.EndTime.ToString(@"hh\:mm")</span>
                        <span>@entry.HoursWorked.ToString("0.##") h</span>
                        <span>@entry.BreakMinutes min Pause</span>
                        <span>@entry.LineTotal.ToString("0.00") EUR</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(entry.Comment))
                    {
                        <p class="entry-comment">@entry.Comment</p>
                    }
                    <div class="status-update">
                        <input placeholder="Rechnungsnr." @bind="InvoiceNumbers[entry.WorkTimeEntryId]" />
                        @if (CanEditEntry(entry))
                        {
                            <button class="ghost-button" @onclick="() => OpenEditDialog(entry)">Bearbeiten</button>
                        }
                        <button class="ghost-button" @onclick="() => MarkInvoicedAsync(entry.WorkTimeEntryId)">Fakturiert</button>
                        <button class="ghost-button" @onclick="() => MarkPaidAsync(entry.WorkTimeEntryId)">Bezahlt</button>
                        <button class="ghost-button danger" @onclick="() => DeleteAsync(entry.WorkTimeEntryId)">Löschen</button>
                    </div>
                </div>
            }
        }
    </div>
</section>

@if (ShowStartDialog)
{
    <div class="modal-backdrop" @onclick="CloseStartDialog">
        <div class="modal-card worktime-start-modal" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>Projekt stechen</h3>
                    <p>Pflichtfelder sind mit * markiert.</p>
                </div>
            </div>

            <div class="form-grid compact-grid">
                <label>
                    <span>Kunde *</span>
                    <select @bind="StartForm.CustomerId" @bind:after="LoadProjectsForSelectedCustomerAsync">
                        <option value="0">Bitte wählen</option>
                        @foreach (var customer in Customers)
                        {
                            <option value="@customer.CustomerId">@customer.Name</option>
                        }
                    </select>
                </label>
                <label>
                    <span>Projekt *</span>
                    <select @bind="StartForm.ProjectId">
                        <option value="">Bitte wählen</option>
                        @foreach (var project in AvailableProjects)
                        {
                            <option value="@project.ProjectId">@project.Name</option>
                        }
                    </select>
                </label>
                <label>
                    <span>Stundensatz</span>
                    <input type="number" step="0.01" @bind="StartForm.HourlyRate" />
                </label>
                <label>
                    <span>Preis / km</span>
                    <input type="number" step="0.01" @bind="StartForm.TravelRatePerKilometer" />
                </label>
                <label class="wide">
                    <span>Beschreibung *</span>
                    <input @bind="StartForm.Description" />
                </label>
            </div>

            <div class="row-actions wrap-mobile">
                <button class="action-button" @onclick="ConfirmStartClockAsync">Projektstart</button>
                <button class="ghost-button" @onclick="CloseStartDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@if (ShowStopDialog)
{
    <div class="modal-backdrop" @onclick="CloseStopDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>Projektzeit beenden</h3>
                    <p>Bitte gib noch einen Kommentar zur abgeschlossenen Arbeit ein.</p>
                </div>
            </div>

            <div class="form-grid compact-grid">
                <label class="wide">
                    <span>Kommentar</span>
                    <textarea rows="4" @bind="StopComment"></textarea>
                </label>
                <label>
                    <span>Anfahrt (km)</span>
                    <input type="number" step="0.01" @bind="StopTravelKilometers" />
                </label>
            </div>

            <div class="row-actions wrap-mobile">
                <button class="action-button" @onclick="ConfirmStopClockAsync">Projektstopp speichern</button>
                <button class="ghost-button" @onclick="CloseStopDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@if (ShowEditDialog)
{
    <div class="modal-backdrop" @onclick="CloseEditDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="table-header compact">
                <div>
                    <h3>@(EditingWorkTimeEntryId.HasValue ? "Arbeitszeit bearbeiten" : "Arbeitszeit nachtragen")</h3>
                    <p>Hier kannst du Arbeitszeiten nachträglich erfassen oder bestehende Einträge anpassen.</p>
                </div>
            </div>

            <div class="form-grid compact-grid">
                <label>
                    <span>Kunde</span>
                    <select @bind="EditForm.CustomerId" @bind:after="LoadProjectsForEditCustomerAsync">
                        @foreach (var customer in Customers)
                        {
                            <option value="@customer.CustomerId">@customer.Name</option>
                        }
                    </select>
                </label>
                <label>
                    <span>Projekt</span>
                    <select @bind="EditForm.ProjectId">
                        <option value="">Ohne Projekt</option>
                        @foreach (var project in EditProjects)
                        {
                            <option value="@project.ProjectId">@project.Name</option>
                        }
                    </select>
                </label>
                <label><span>Datum</span><input type="date" value="@EditWorkDateText" @onchange="OnEditWorkDateChanged" /></label>
                <label><span>Beschreibung</span><input @bind="EditForm.Description" /></label>
                <label><span>Beginn</span><input type="time" value="@EditStartTimeText" @onchange="OnEditStartTimeChanged" /></label>
                <label><span>Ende</span><input type="time" value="@EditEndTimeText" @onchange="OnEditEndTimeChanged" /></label>
                <label><span>Pause (Min.)</span><input type="number" @bind="EditForm.BreakMinutes" /></label>
                <label><span>Stundensatz</span><input type="number" step="0.01" @bind="EditForm.HourlyRate" /></label>
                <label><span>Anfahrt (km)</span><input type="number" step="0.01" @bind="EditForm.TravelKilometers" /></label>
                <label><span>Preis / km</span><input type="number" step="0.01" @bind="EditForm.TravelRatePerKilometer" /></label>
                <label class="wide"><span>Kommentar</span><textarea rows="4" @bind="EditForm.Comment"></textarea></label>
            </div>

            <div class="row-actions wrap-mobile">
                <button class="action-button" @onclick="SaveEditAsync">Änderungen speichern</button>
                <button class="ghost-button" @onclick="CloseEditDialog">Abbrechen</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CustomerItem> Customers { get; set; } = [];
    private List<ProjectItem> AvailableProjects { get; set; } = [];
    private List<ProjectItem> FilterProjects { get; set; } = [];
    private List<ProjectItem> EditProjects { get; set; } = [];
    private List<WorkTimeItem> Entries { get; set; } = [];
    private WorkTimeItem? ActiveClock { get; set; }
    private StartWorkTimeClockModel StartForm { get; set; } = new();
    private SaveWorkTimeModel EditForm { get; set; } = new();
    private Dictionary<int, string?> InvoiceNumbers { get; set; } = [];
    private int? FilterCustomerId { get; set; }
    private int? FilterProjectId { get; set; }
    private bool ShowStopDialog { get; set; }
    private bool ShowStartDialog { get; set; }
    private bool ShowEditDialog { get; set; }
    private int? EditingWorkTimeEntryId { get; set; }
    private string StopComment { get; set; } = "";
    private decimal StopTravelKilometers { get; set; }
    private bool StatusIsWarning { get; set; }
    private string? StatusMessage { get; set; }
    private string EditWorkDateText => EditForm.WorkDate.ToString("yyyy-MM-dd");
    private string EditStartTimeText => EditForm.StartTime.ToString(@"hh\:mm");
    private string EditEndTimeText => EditForm.EndTime.ToString(@"hh\:mm");
    private int? CurrentUserId => Auth.CurrentSession?.User.AppUserId;

    protected override async Task OnParametersSetAsync()
    {
        if (!Auth.IsInitialized || !Auth.IsAuthenticated)
        {
            Customers = [];
            AvailableProjects = [];
            FilterProjects = [];
            Entries = [];
            ActiveClock = null;
            return;
        }

        await Offline.SyncPendingAsync();
        Customers = (await Offline.GetCustomersAsync(activeProjectsOnly: true)).ToList();
        if (Customers.Count == 0)
        {
            AvailableProjects = [];
            FilterProjects = [];
            Entries = [];
            ActiveClock = null;
            return;
        }

        if (UiState.SelectedCustomerId.HasValue && Customers.Any(x => x.CustomerId == UiState.SelectedCustomerId.Value))
        {
            StartForm.CustomerId = UiState.SelectedCustomerId.Value;
            FilterCustomerId = UiState.SelectedCustomerId.Value;
        }
        else if (StartForm.CustomerId <= 0 || Customers.All(x => x.CustomerId != StartForm.CustomerId))
        {
            StartForm.CustomerId = Customers[0].CustomerId;
        }

        if (!FilterCustomerId.HasValue || Customers.All(x => x.CustomerId != FilterCustomerId.Value))
        {
            FilterCustomerId = Customers[0].CustomerId;
        }

        await LoadProjectsForSelectedCustomerAsync();
        await HandleFilterCustomerChangedAsync();
        await ReloadActiveClockAsync();
    }

    private async Task ReloadAsync()
    {
        await ReloadActiveClockAsync();
        await ReloadEntriesAsync();
    }

    private async Task ReloadActiveClockAsync()
    {
        ActiveClock = await (await Offline.IsOnlineAsync() ? Api.GetActiveWorkTimeClockAsync() : Task.FromResult<WorkTimeItem?>(null));
    }

    private async Task ReloadEntriesAsync()
    {
        Entries = (await Offline.GetWorkTimesAsync(FilterCustomerId, FilterProjectId))
            .OrderByDescending(x => x.WorkDate)
            .ThenByDescending(x => x.StartTime)
            .ToList();
        InvoiceNumbers = Entries.ToDictionary(x => x.WorkTimeEntryId, x => x.CustomerInvoiceNumber);
    }

    private async Task LoadProjectsForSelectedCustomerAsync()
    {
        UiState.SetSelectedCustomer(StartForm.CustomerId > 0 ? StartForm.CustomerId : null);
        AvailableProjects = StartForm.CustomerId > 0 ? (await Offline.GetProjectsAsync(StartForm.CustomerId, includeInactive: false)).ToList() : [];
        if (StartForm.ProjectId.HasValue && AvailableProjects.All(x => x.ProjectId != StartForm.ProjectId.Value))
        {
            StartForm.ProjectId = null;
        }
    }

    private async Task HandleFilterCustomerChangedAsync()
    {
        UiState.SetSelectedCustomer(FilterCustomerId);
        if (FilterCustomerId.HasValue)
        {
            StartForm.CustomerId = FilterCustomerId.Value;
        }
        FilterProjects = FilterCustomerId.HasValue ? (await Offline.GetProjectsAsync(FilterCustomerId.Value, includeInactive: false)).ToList() : [];
        if (FilterProjectId.HasValue && FilterProjects.All(x => x.ProjectId != FilterProjectId.Value))
        {
            FilterProjectId = null;
        }

        await ReloadEntriesAsync();
    }

    private async Task StartClockAsync()
    {
        if (!await Offline.IsOnlineAsync())
        {
            SetStatus("Projekt stechen ist offline aktuell nicht verfügbar. Bitte Arbeitszeit nachtragen nutzen.", true);
            return;
        }

        if (StartForm.CustomerId <= 0)
        {
            SetStatus("Bitte zuerst einen Kunden wählen.", true);
            return;
        }

        if (!StartForm.ProjectId.HasValue)
        {
            SetStatus("Bitte ein konkretes Projekt auswählen.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(StartForm.Description))
        {
            SetStatus("Bitte eine Beschreibung eingeben.", true);
            return;
        }

        StartForm.StartedAt = DateTimeOffset.Now;
        ActiveClock = await Api.StartWorkTimeClockAsync(StartForm);
        SetStatus($"Projektzeit für {ActiveClock.ProjectName} gestartet.", false);
        await ReloadEntriesAsync();
    }

    private void OpenStartDialog()
    {
        if (ActiveClock is not null)
        {
            return;
        }

        ShowStartDialog = true;
    }

    private void CloseStartDialog()
    {
        ShowStartDialog = false;
    }

    private async Task ConfirmStartClockAsync()
    {
        await StartClockAsync();
        if (ActiveClock is not null)
        {
            ShowStartDialog = false;
        }
    }

    private async Task TogglePauseAsync()
    {
        if (ActiveClock is null)
        {
            return;
        }

        var changedAt = new ChangeWorkTimePauseModel { ChangedAt = DateTimeOffset.Now };
        ActiveClock = ActiveClock.PauseStartedAtUtc.HasValue
            ? await Api.StopWorkTimePauseAsync(changedAt)
            : await Api.StartWorkTimePauseAsync(changedAt);

        SetStatus(ActiveClock.PauseStartedAtUtc.HasValue ? "Pause gestartet." : $"Pause gespeichert. Gesamtpause: {ActiveClock.BreakMinutes} Minuten.", false);
        await ReloadEntriesAsync();
    }

    private void OpenStopDialog()
    {
        StopComment = "";
        StopTravelKilometers = ActiveClock?.TravelKilometers ?? 0m;
        ShowStopDialog = true;
    }

    private void CloseStopDialog()
    {
        ShowStopDialog = false;
    }

    private async Task LoadProjectsForEditCustomerAsync()
    {
        EditProjects = EditForm.CustomerId > 0 ? (await Offline.GetProjectsAsync(EditForm.CustomerId, includeInactive: false)).ToList() : [];
        if (EditForm.ProjectId.HasValue && EditProjects.All(x => x.ProjectId != EditForm.ProjectId.Value))
        {
            EditForm.ProjectId = null;
        }
    }

    private void OpenEditDialog(WorkTimeItem entry)
    {
        EditingWorkTimeEntryId = entry.WorkTimeEntryId;
        EditForm = new SaveWorkTimeModel
        {
            CustomerId = entry.CustomerId,
            ProjectId = entry.ProjectId,
            WorkDate = entry.WorkDate.Date,
            StartTime = entry.StartTime,
            EndTime = entry.EndTime,
            BreakMinutes = entry.BreakMinutes,
            HourlyRate = entry.HourlyRate,
            TravelKilometers = entry.TravelKilometers,
            TravelRatePerKilometer = entry.TravelRatePerKilometer,
            Description = entry.Description,
            Comment = entry.Comment
        };
        _ = LoadProjectsForEditCustomerAsync();
        ShowEditDialog = true;
    }

    private void OpenCreateEntryDialog()
    {
        if (Customers.Count == 0)
        {
            SetStatus("Es sind aktuell keine aktiven Kunden mit Projekt verfügbar.", true);
            return;
        }

        EditingWorkTimeEntryId = null;
        EditForm = new SaveWorkTimeModel
        {
            CustomerId = Customers.FirstOrDefault()?.CustomerId ?? 0,
            WorkDate = DateTime.Today,
            StartTime = new TimeSpan(8, 0, 0),
            EndTime = new TimeSpan(16, 30, 0),
            BreakMinutes = 30,
            HourlyRate = 65m,
            Description = "Arbeitszeit"
        };
        _ = LoadProjectsForEditCustomerAsync();
        ShowEditDialog = true;
    }

    private void CloseEditDialog()
    {
        ShowEditDialog = false;
        EditingWorkTimeEntryId = null;
    }

    private void OnEditWorkDateChanged(ChangeEventArgs args)
    {
        EditForm.WorkDate = DateTime.TryParse(args.Value?.ToString(), out var result) ? result.Date : DateTime.Today;
    }

    private void OnEditStartTimeChanged(ChangeEventArgs args)
    {
        EditForm.StartTime = TimeSpan.TryParse(args.Value?.ToString(), out var result) ? result : new TimeSpan(8, 0, 0);
    }

    private void OnEditEndTimeChanged(ChangeEventArgs args)
    {
        EditForm.EndTime = TimeSpan.TryParse(args.Value?.ToString(), out var result) ? result : new TimeSpan(16, 30, 0);
    }

    private async Task SaveEditAsync()
    {
        if (EditForm.CustomerId <= 0)
        {
            SetStatus("Bitte einen Kunden auswählen.", true);
            return;
        }

        if ((EditForm.EndTime - EditForm.StartTime - TimeSpan.FromMinutes(EditForm.BreakMinutes)) <= TimeSpan.Zero)
        {
            SetStatus("Bitte gültige Start-, End- und Pausenzeiten eingeben.", true);
            return;
        }

        if (EditingWorkTimeEntryId.HasValue)
        {
            Entries = await Offline.SaveWorkTimeAsync(EditForm, EditingWorkTimeEntryId.Value, FilterCustomerId, FilterProjectId);
        }
        else
        {
            Entries = await Offline.SaveWorkTimeAsync(EditForm, null, FilterCustomerId, FilterProjectId);
        }

        CloseEditDialog();
        SetStatus(EditingWorkTimeEntryId.HasValue ? "Arbeitszeit wurde aktualisiert." : "Arbeitszeit wurde nachgetragen.", false);
        await ReloadAsync();
    }

    private async Task ConfirmStopClockAsync()
    {
        if (ActiveClock is null)
        {
            ShowStopDialog = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(StopComment))
        {
            SetStatus("Bitte beim Projektstopp einen Kommentar eingeben.", true);
            return;
        }

        ActiveClock = await Api.StopWorkTimeClockAsync(new StopWorkTimeClockModel
        {
            EndedAt = DateTimeOffset.Now,
            TravelKilometers = StopTravelKilometers,
            Comment = StopComment.Trim()
        });

        ShowStopDialog = false;
        SetStatus("Projektzeit beendet und gespeichert.", false);
        await ReloadAsync();
        ActiveClock = null;
    }

    private async Task MarkInvoicedAsync(int id)
    {
        if (!await Offline.IsOnlineAsync())
        {
            SetStatus("Faktura-Status kann aktuell nur online geändert werden.", true);
            return;
        }

        await Api.UpdateWorkTimeStatusAsync(id, new UpdateWorkTimeStatusModel { CustomerInvoiceNumber = InvoiceNumbers.GetValueOrDefault(id), MarkInvoiced = true });
        SetStatus("Eintrag als fakturiert markiert.", false);
        await ReloadEntriesAsync();
    }

    private async Task MarkPaidAsync(int id)
    {
        if (!await Offline.IsOnlineAsync())
        {
            SetStatus("Bezahlstatus kann aktuell nur online geändert werden.", true);
            return;
        }

        await Api.UpdateWorkTimeStatusAsync(id, new UpdateWorkTimeStatusModel { CustomerInvoiceNumber = InvoiceNumbers.GetValueOrDefault(id), MarkPaid = true });
        SetStatus("Eintrag als bezahlt markiert.", false);
        await ReloadEntriesAsync();
    }

    private async Task DeleteAsync(int id)
    {
        Entries = await Offline.DeleteWorkTimeAsync(id, FilterCustomerId, FilterProjectId);
        SetStatus("Eintrag gelöscht.", false);
        await ReloadAsync();
    }

    private bool CanEditEntry(WorkTimeItem entry)
        => !entry.IsClockActive && (Auth.CanManageUsers || (entry.AppUserId.HasValue && entry.AppUserId == CurrentUserId));

    private void SetStatus(string message, bool isWarning)
    {
        StatusMessage = message;
        StatusIsWarning = isWarning;
    }
}
