<Page x:Class="InvoiceWizard.WorkTimePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="860" d:DesignWidth="1280"
      Title="WorkTimePage">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Arbeitszeit" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Starte Projektzeiten wie an einer Stechuhr. Projektstart, Pause und Projektstopp werden sofort gespeichert." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Projekt stechen" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Projekt waehlen und direkt starten. Solange eine Zeit laeuft, bleibt die Auswahl gesperrt." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,16" TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,0,0,14">
                        <StackPanel Width="240" Margin="0,0,14,12">
                            <TextBlock Text="Kunde" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="CustomerCombo" DisplayMemberPath="Name" SelectionChanged="CustomerCombo_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Width="240" Margin="0,0,14,12">
                            <TextBlock Text="Projekt" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="ProjectCombo" DisplayMemberPath="Name" SelectionChanged="ProjectCombo_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Width="120" Margin="0,0,14,12">
                            <TextBlock Text="Stundensatz" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="HourlyRateText" Text="65"/>
                        </StackPanel>
                        <StackPanel Width="120" Margin="0,0,14,12">
                            <TextBlock Text="Preis / km" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="TravelRateText" Text="0"/>
                        </StackPanel>
                        <StackPanel Width="260" Margin="0,0,14,12">
                            <TextBlock Text="Beschreibung" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="DescriptionText" Text="Arbeitszeit"/>
                        </StackPanel>
                    </WrapPanel>

                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushTheme}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Aktive Projektzeit" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                            <TextBlock x:Name="ActiveClockText" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="PauseInfoText" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <WrapPanel>
                        <Button Width="160" Height="40" Margin="0,0,10,0" Content="Projektstart" Click="StartProject_Click"/>
                        <Button x:Name="PauseButton" Width="160" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Pause starten" Click="PauseProject_Click"/>
                        <Button x:Name="StopButton" Width="160" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Projektstopp" Click="StopProject_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Aktionen" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Filter und Export fuer bereits erfasste Zeiten." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,16" TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,0,0,14">
                        <Button Width="160" Height="40" Margin="0,0,10,10" Content="Aktualisieren" Click="Refresh_Click"/>
                        <Button Width="170" Height="40" Margin="0,0,10,10" Content="Arbeitszeiten als PDF" Click="ExportPdf_Click"/>
                        <Button Width="170" Height="40" Margin="0,0,10,10" Style="{StaticResource SecondaryButtonStyle}" Content="Markierte loeschen" Click="DeleteSelected_Click"/>
                    </WrapPanel>
                    <TextBlock Text="Laufende Zeiten werden sofort gespeichert und erscheinen direkt unten in der Liste." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Erfasste Arbeitszeiten" Style="{StaticResource SectionTitleStyle}" Margin="18,18,18,0"/>
                <DataGrid x:Name="WorkEntriesGrid" Grid.Row="1" Margin="0,16,0,0" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Datum" Binding="{Binding WorkDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                        <DataGridTextColumn Header="Benutzer" Binding="{Binding UserDisplayName}" Width="150"/>
                        <DataGridTextColumn Header="Projekt" Binding="{Binding Project.Name}" Width="180"/>
                        <DataGridTextColumn Header="Zeit" Binding="{Binding TimeRange}" Width="120"/>
                        <DataGridTextColumn Header="Pause" Binding="{Binding BreakMinutes}" Width="80"/>
                        <DataGridTextColumn Header="Stunden" Binding="{Binding HoursWorked}" Width="90"/>
                        <DataGridTextColumn Header="Stundensatz" Binding="{Binding HourlyRate}" Width="100"/>
                        <DataGridTextColumn Header="Anfahrt km" Binding="{Binding TravelKilometers}" Width="100"/>
                        <DataGridTextColumn Header="Preis/km" Binding="{Binding TravelRatePerKilometer}" Width="95"/>
                        <DataGridTextColumn Header="Gesamt" Binding="{Binding CalculatedLineTotal}" Width="100"/>
                        <DataGridTextColumn Header="Kommentar" Binding="{Binding Comment}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border x:Name="StatusBorder" Grid.Row="3" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
