<Page x:Class="InvoiceWizard.SoneparPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SoneparPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Sonepar" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Mandantenbezogene Sonepar-Anmeldung speichern, Produktsuche ausfuehren und Artikeldetails inklusive Preis ansehen." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Margin="0,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Benutzername" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="UsernameTextBox" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Passwort" Style="{StaticResource MutedLabelStyle}"/>
                            <PasswordBox x:Name="PasswordBox" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Kundennummer" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="CustomerNumberTextBox" Margin="0,8,0,0"/>
                            <TextBlock x:Name="CustomerNumberMaskedText" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,16,12,0">
                            <TextBlock Text="Client ID" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="ClientIdTextBox" Margin="0,8,0,0"/>
                            <TextBlock x:Name="ClientIdMaskedText" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,16,12,0">
                            <TextBlock Text="Organization ID" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="OrganizationIdTextBox" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,16,0,0">
                            <TextBlock Text="OMD Version" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="OmdVersionComboBox" Margin="0,8,0,0" SelectedIndex="2">
                                <ComboBoxItem Content="1.0.5"/>
                                <ComboBoxItem Content="1.1.0"/>
                                <ComboBoxItem Content="9.0.1"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,16,12,0">
                            <TextBlock Text="Token URL" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="TokenUrlTextBox" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,16,0,0">
                            <TextBlock Text="Open Masterdata Base URL" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="OpenMasterDataBaseUrlTextBox" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" Width="180">
                        <Button Height="40" Content="Zugang speichern" Click="SaveConnection_Click"/>
                        <Button x:Name="DeleteConnectionButton" Height="40" Margin="0,10,0,0" Style="{StaticResource SecondaryButtonStyle}" Content="Bei Sonepar abmelden" Click="DeleteConnection_Click"/>
                        <Button Height="40" Margin="0,10,0,0" Style="{StaticResource SecondaryButtonStyle}" Content="Neu laden" Click="Reload_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Suche nach" Style="{StaticResource MutedLabelStyle}"/>
                        <ComboBox x:Name="SearchTypeComboBox" Margin="0,8,0,0" SelectedIndex="0">
                            <ComboBoxItem Tag="SupplierPid" Content="Lieferanten-Artikelnr."/>
                            <ComboBoxItem Tag="Gtin" Content="GTIN / EAN"/>
                            <ComboBoxItem Tag="ManufacturerData" Content="Herstellerdaten"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Suchbegriff" Style="{StaticResource MutedLabelStyle}"/>
                        <TextBox x:Name="SearchQueryTextBox" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" Width="150" Height="40" Margin="0,24,0,0" Content="Produkte suchen" Click="Search_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="DATANORM vom Großhändler" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="DatanormSummaryText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="Noch keine DATANORM-Datei importiert."/>
                        <TextBlock x:Name="DatanormPreviewText"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Width="190" Height="40" Margin="0,0,10,0" Content="DATANORM importieren" Click="ImportDatanorm_Click"/>
                        <Button Width="190" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="DATANORM durchsuchen" Click="OpenDatanormSearch_Click"/>
                        <Button Width="130" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Katalog neu laden" Click="ReloadDatanorm_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Suchergebnisse" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="SearchSummaryText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        <DataGrid x:Name="ProductsGrid" Margin="0,16,0,0" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" MinHeight="420" SelectionChanged="ProductsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Artikelnr." Binding="{Binding SupplierPid}" Width="130"/>
                                <DataGridTextColumn Header="GTIN" Binding="{Binding Gtin}" Width="140"/>
                                <DataGridTextColumn Header="Bezeichnung" Binding="{Binding DescriptionShort}" Width="*"/>
                                <DataGridTextColumn Header="Hersteller" Binding="{Binding ManufacturerName}" Width="140"/>
                                <DataGridTextColumn Header="Netto" Binding="{Binding NetPriceLabel}" Width="110"/>
                                <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Produktdetails" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock x:Name="DetailHeaderText" Margin="0,14,0,0" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DetailMetaText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DetailDescriptionText" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Rohdaten" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBox x:Name="RawJsonTextBox" Margin="0,14,0,0" MinHeight="240" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="StatusBorder" Grid.Row="5" Margin="0,16,0,0" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
