<Page x:Class="InvoiceWizard.SubscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SubscriptionPage">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Abo und Lizenz" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Hier siehst du den aktuellen Tarif deiner Firma und kannst als Admin eine Kuendigung vormerken." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Firma" Style="{StaticResource MutedLabelStyle}"/>
                    <TextBox x:Name="TenantNameText" IsReadOnly="True"/>
                    <TextBlock Text="Tarif" Style="{StaticResource MutedLabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="PlanText" IsReadOnly="True"/>
                    <TextBlock Text="Abo" Style="{StaticResource MutedLabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="BillingText" IsReadOnly="True"/>
                    <TextBlock Text="Status" Style="{StaticResource MutedLabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="StatusTextBox" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Gueltig bis" Style="{StaticResource MutedLabelStyle}"/>
                    <TextBox x:Name="ValidUntilText" IsReadOnly="True"/>
                    <TextBlock Text="Naechste Abbuchung" Style="{StaticResource MutedLabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="NextBillingDateText" IsReadOnly="True"/>
                    <TextBlock Text="Grace bis" Style="{StaticResource MutedLabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="GraceUntilText" IsReadOnly="True"/>
                    <TextBlock Text="Gekuendigt am" Style="{StaticResource MutedLabelStyle}" Margin="0,12,0,0"/>
                    <TextBox x:Name="CancelledAtText" IsReadOnly="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="HintText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Abo-Modell wechseln" Style="{StaticResource MutedLabelStyle}"/>
                        <ComboBox x:Name="PlanCombo" Margin="0,8,0,0" DisplayMemberPath="DisplayLabel"/>
                    </StackPanel>
                    <Button x:Name="SavePlanButton" Grid.Column="1" Width="180" Height="40" Margin="0,24,0,0" Content="Abo-Modell speichern" Click="SavePlan_Click"/>
                </Grid>
                <WrapPanel Margin="0,16,0,0">
                    <Button x:Name="CancelSubscriptionButton" Width="180" Height="40" Margin="0,0,10,0" Content="Abo kuendigen" Click="CancelSubscription_Click"/>
                    <Button Width="130" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Aktualisieren" Click="Refresh_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border x:Name="StatusBorder" Grid.Row="3" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Page>
