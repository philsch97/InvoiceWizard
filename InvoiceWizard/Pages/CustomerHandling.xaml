<Page x:Class="InvoiceWizard.CustomerHandling"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1320"
      Title="CustomerHandling">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Kundenpflege" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Hier pflegst du Kundenstamm und Projekte getrennt von der spaeteren Abrechnung." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.8*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Kundenstamm" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Kunden koennen hier angelegt, nachtraeglich bearbeitet und geloescht werden. Projekte legst und pflegst du jetzt auf der Seite Projektdaten." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,16" TextWrapping="Wrap"/>

                        <TextBlock Text="Kunde" Style="{StaticResource MutedLabelStyle}"/>
                        <ComboBox x:Name="CustomerCombo" DisplayMemberPath="Name" SelectedValuePath="CustomerId" SelectionChanged="CustomerCombo_SelectionChanged" Margin="0,0,0,18"/>

                        <Border Background="#202730" CornerRadius="14" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Projektpflege" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Auf der Seite Projektdaten kannst du Projekte jetzt neu anlegen, bearbeiten, pausieren oder beenden." Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Kundendaten" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Die Rechnungsadresse bleibt optional. Wenn Vor- und Nachname geaendert werden, wird der Anzeigename automatisch angepasst." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,16" TextWrapping="Wrap"/>

                        <TextBlock Text="Kundennummer" Style="{StaticResource MutedLabelStyle}"/>
                        <TextBox x:Name="CustomerNumberText" IsReadOnly="True" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Vorname" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerFirstNameText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Nachname" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerLastNameText"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Strasse" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerStreetText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Hausnummer" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerHouseNumberText"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.4*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Postleitzahl" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerPostalCodeText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Ort" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerCityText"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="E-Mail-Adresse" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerEmailText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Telefonnummer" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="CustomerPhoneText"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Standard-Zuschlag %" Style="{StaticResource MutedLabelStyle}"/>
                        <TextBox x:Name="DefaultMarkupText" Text="0" Margin="0,0,0,14"/>

                        <WrapPanel>
                            <Button Width="170" Height="40" Margin="0,0,10,10" Content="Neuen Kunden anlegen" Click="AddCustomer_Click"/>
                            <Button Width="190" Height="40" Margin="0,0,10,10" Style="{StaticResource SecondaryButtonStyle}" Content="Ausgewaehlten aktualisieren" Click="UpdateCustomer_Click"/>
                            <Button Width="140" Height="40" Margin="0,0,10,10" Style="{StaticResource SecondaryButtonStyle}" Content="Formular leeren" Click="ClearCustomerForm_Click"/>
                            <Button Width="150" Height="40" Margin="0,0,0,10" Style="{StaticResource SecondaryButtonStyle}" Content="Kunde loeschen" Click="DeleteCustomer_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="StatusBorder" Grid.Row="2" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12" Margin="0,16,0,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
