<Page x:Class="InvoiceWizard.InvoiceArchivePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="InvoiceArchivePage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Rechnungsarchiv" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Verwalte hier gespeicherte Eingangs- und Ausgangsrechnungen, bearbeite Entwuerfe und exportiere PDFs gesammelt."
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Gespeicherte Rechnungen" Style="{StaticResource SectionTitleStyle}" Margin="18,18,18,0"/>

                    <WrapPanel Grid.Column="1" Margin="0,18,18,0">
                        <Button Width="170" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Entwurf bearbeiten" Click="EditDraftInvoice_Click"/>
                        <Button Width="170" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Entwurf finalisieren" Click="FinalizeDraftInvoice_Click"/>
                        <Button Width="160" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Rechnung loeschen" Click="DeleteInvoices_Click"/>
                        <Button Width="160" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Rechnung stornieren" Click="CancelInvoice_Click"/>
                        <Button Width="190" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="PDF nachtraeglich hinterlegen" Click="UploadStoredPdf_Click"/>
                        <Button Width="150" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Rechnung ansehen" Click="OpenStoredPdf_Click"/>
                        <Button Width="180" Height="36" Style="{StaticResource SecondaryButtonStyle}" Content="PDFs in Ordner exportieren" Click="ExportStoredPdfs_Click"/>
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="18,16,18,0">
                        <StackPanel Width="230" Margin="0,0,14,12">
                            <TextBlock Text="Rechnungsform" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="InvoiceDirectionFilterCombo" DisplayMemberPath="Label" SelectedValuePath="Value" SelectionChanged="ArchiveFilter_Changed"/>
                        </StackPanel>
                        <StackPanel Width="260" Margin="0,0,14,12">
                            <TextBlock Text="Kunde" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="CustomerFilterCombo" DisplayMemberPath="Name" SelectedValuePath="CustomerId" SelectionChanged="CustomerFilterCombo_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Width="260" Margin="0,0,14,12">
                            <TextBlock Text="Projekt" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="ProjectFilterCombo" DisplayMemberPath="Name" SelectedValuePath="ProjectId" SelectionChanged="ArchiveFilter_Changed"/>
                        </StackPanel>
                        <Button Width="140" Height="40" Margin="0,24,0,12" Style="{StaticResource SecondaryButtonStyle}" Content="Filter reset" Click="ResetFilters_Click"/>
                    </WrapPanel>

                    <DataGrid x:Name="InvoicesGrid"
                              Grid.Row="2"
                              Grid.ColumnSpan="2"
                              Margin="0,16,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              MinHeight="420">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rechnung" Binding="{Binding DisplayNumber}" Width="160"/>
                            <DataGridTextColumn Header="Art" Binding="{Binding InvoiceDirectionLabel}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding InvoiceStatusLabel}" Width="90"/>
                            <DataGridTextColumn Header="Datum" Binding="{Binding InvoiceDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Partei" Binding="{Binding ArchivePartyName}" Width="220"/>
                            <DataGridTextColumn Header="Kategorie" Binding="{Binding AccountingCategoryLabel}" Width="150"/>
                            <DataGridTextColumn Header="Beleg" Binding="{Binding ExpenseStatus}" Width="120"/>
                            <DataGridCheckBoxColumn Header="PDF" Binding="{Binding HasStoredPdf}" Width="70"/>
                            <DataGridTextColumn Header="Datei" Binding="{Binding OriginalPdfFileName}" Width="260"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border x:Name="StatusBorder"
                    Grid.Row="2"
                    Background="{StaticResource StatusInfoBackgroundBrush}"
                    BorderBrush="{StaticResource StatusInfoBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,12"
                    Margin="0,16,0,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
