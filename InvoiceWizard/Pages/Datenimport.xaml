<Page x:Class="InvoiceWizard.Datenimport"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Datenimport">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ImportRoot" Margin="18" AllowDrop="True" PreviewDragOver="ImportRoot_PreviewDragOver" DragLeave="ImportRoot_DragLeave" Drop="ImportRoot_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Rechnungsimport" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="PDFs werden automatisch auf ZUGFeRD geprüft und immer zuerst als Prüfrechnung importiert. Mehrere Dateien können direkt per Drag-and-Drop auf diese Seite gelegt oder gemeinsam im Dateidialog ausgewählt werden."
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="18,2,0,0"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>

                    <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,18,0,0">
                        <Button Width="190" Height="40" Margin="0,0,10,0" Content="PDF(s) laden" Click="ChoosePdf_Click"/>
                        <Button Width="190" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Positionen bearbeiten" Click="EditManualLines_Click"/>
                        <Button x:Name="SaveInvoiceButton" Width="190" Height="40" Content="Rechnung speichern" Click="SaveInvoice_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock x:Name="InvoiceNumberLabel" Text="Rechnungsnummer * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="InvoiceNumberText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock x:Name="InvoiceDateLabel" Text="Rechnungsdatum * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <DatePicker x:Name="InvoiceDatePicker"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock x:Name="PartyLabelText" Text="Lieferant optional" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="SupplierNameText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock Text="Kategorie * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <ComboBox x:Name="AccountingCategoryCombo"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock Text="Rechnungsart * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <ComboBox x:Name="InvoiceDirectionCombo" SelectionChanged="InvoiceDirectionCombo_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock x:Name="InvoiceTotalAmountLabel" Text="Rechnungsbetrag * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="InvoiceTotalAmountText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock x:Name="PaymentDueDateLabel" Text="Zahlbar bis / Fällig am optional" Style="{StaticResource MutedLabelStyle}"/>
                            <DatePicker x:Name="PaymentDueDatePicker"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock Text="Quelle optional" Style="{StaticResource MutedLabelStyle}"/>
                            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushTheme}" BorderThickness="1" CornerRadius="12" Padding="12,10">
                                <TextBlock x:Name="SourceInfoText" Text="Manuelle Erfassung" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock Text="Versandkosten" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="ShippingCostText" Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock Text="Versand behandelt als" Style="{StaticResource MutedLabelStyle}"/>
                            <ComboBox x:Name="ShippingAmountModeCombo" SelectedIndex="0">
                                <ComboBoxItem Content="Brutto"/>
                                <ComboBoxItem Content="Netto"/>
                            </ComboBox>
                            <TextBlock x:Name="ShippingInfoText"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="Versand wird anteilig auf alle Positionen verteilt."/>
                        </StackPanel>

                        <CheckBox x:Name="NoSupplierInvoiceCheckBox"
                                  Grid.Row="5"
                                  Grid.ColumnSpan="2"
                                  Margin="0,16,0,0"
                                  Content="Ohne Rechnungsbeleg erfassen"
                                  Checked="NoSupplierInvoiceCheckBox_Changed"
                                  Unchecked="NoSupplierInvoiceCheckBox_Changed"/>

                        <TextBlock x:Name="InvoiceDirectionHintText"
                                   Grid.Row="6"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="18,18,18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Importierte Rechnungen" Style="{StaticResource SectionTitleStyle}"/>
                            <WrapPanel Grid.Column="1">
                                <Button Width="170" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Prüfrechnung laden" Click="LoadReviewInvoice_Click"/>
                                <Button Width="170" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Prüfrechnung löschen" Click="DeleteReviewInvoices_Click"/>
                                <Button Width="150" Height="36" Style="{StaticResource SecondaryButtonStyle}" Content="Rechnung ansehen" Click="OpenStoredPdf_Click"/>
                            </WrapPanel>
                        </Grid>
                        <DataGrid x:Name="InvoicesGrid"
                                  Grid.Row="1"
                                  Margin="0,16,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Extended"
                                  MinHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Rechnungsnummer" Binding="{Binding DisplayNumber}" Width="180"/>
                                <DataGridTextColumn Header="Lieferant" Binding="{Binding SupplierName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Positionen der aktuellen Erfassung" Style="{StaticResource SectionTitleStyle}" Margin="18,18,18,0"/>
                    <DataGrid x:Name="ManualLinesGrid"
                              Grid.Row="1"
                              Margin="0,16,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pos." Binding="{Binding Position}" Width="60"/>
                            <DataGridTextColumn Header="Artikel" Binding="{Binding ArticleNumber}" Width="120"/>
                            <DataGridTextColumn Header="EAN" Binding="{Binding Ean}" Width="140"/>
                            <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Menge" Binding="{Binding Quantity}" Width="90"/>
                            <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="80"/>
                            <DataGridTextColumn Header="Gesamtbrutto&#10;pro Einheit" Binding="{Binding GrossUnitPrice, StringFormat={}{0:N2} &#x20AC;}" Width="160"/>
                            <DataGridTextColumn Header="Gesamtnetto&#10;pro Einheit" Binding="{Binding EffectiveNetUnitPrice, StringFormat={}{0:N2} &#x20AC;}" Width="170"/>
                            <DataGridTextColumn Header="Netto&#10;pro Basis" Binding="{Binding NetUnitPrice, StringFormat={}{0:N2} &#x20AC;}" Width="120"/>
                            <DataGridTextColumn Header="Materialzuschlag&#10;pro Basis" Binding="{Binding MetalSurcharge, StringFormat={}{0:N2} &#x20AC;}" Width="170"/>
                            <DataGridTextColumn Header="Basis" Binding="{Binding PriceBasisQuantity}" Width="80"/>
                            <DataGridTextColumn Header="Gesamtpreis&#10;Netto" Binding="{Binding LineTotal, StringFormat={}{0:N2} &#x20AC;}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border x:Name="StatusBorder" Grid.Row="3" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
            </Border>

            <Border x:Name="DropOverlay"
                    Grid.RowSpan="5"
                    Background="#B2000000"
                    CornerRadius="18"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Panel.ZIndex="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Datei loslassen, um sie zu importieren"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="PDFs werden automatisch geprüft und als Prüfrechnung angelegt."
                               Foreground="#E5FFFFFF"
                               Margin="0,12,0,0"
                               FontSize="16"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>



