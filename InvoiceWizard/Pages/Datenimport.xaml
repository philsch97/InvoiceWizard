<Page x:Class="InvoiceWizard.Datenimport"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Datenimport">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18" AllowDrop="True" PreviewDragOver="ImportRoot_PreviewDragOver" Drop="ImportRoot_Drop">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Rechnungsimport" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="Importiere ZUGFeRD-Dateien, erfasse klassische Rechnungen manuell oder lege Materialpositionen ohne Lieferantenrechnung an." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Mehrere PDFs koennen direkt per Drag-and-Drop auf diese Seite gelegt oder gemeinsam im Dateidialog ausgewaehlt werden. Mehrfachimporte landen zuerst im Status Prüfen." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="1" Margin="0,18,0,0">
                        <Button Width="190" Height="40" Margin="0,0,10,0" Content="ZUGFeRD-PDF(s) laden" Click="ChoosePdf_Click"/>
                        <Button Width="190" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="PDF-Rechnung(en) laden" Click="ChooseClassicPdf_Click"/>
                        <Button x:Name="SaveInvoiceButton" Width="190" Height="40" Content="Rechnung speichern" Click="SaveInvoice_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock x:Name="InvoiceNumberLabel" Text="Rechnungsnummer * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="InvoiceNumberText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock x:Name="InvoiceDateLabel" Text="Rechnungsdatum * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <DatePicker x:Name="InvoiceDatePicker"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock x:Name="PartyLabelText" Text="Lieferant optional" Style="{StaticResource MutedLabelStyle}"/>
                            <TextBox x:Name="SupplierNameText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock Text="Kategorie * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <ComboBox x:Name="AccountingCategoryCombo"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock Text="Rechnungsart * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <ComboBox x:Name="InvoiceDirectionCombo" SelectionChanged="InvoiceDirectionCombo_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock x:Name="InvoiceTotalAmountLabel" Text="Rechnungsbetrag * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="InvoiceTotalAmountText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,16,12,0">
                            <TextBlock x:Name="PaymentDueDateLabel" Text="Zahlbar bis / Fällig am optional" Style="{StaticResource MutedLabelStyle}"/>
                            <DatePicker x:Name="PaymentDueDatePicker"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock Text="Quelle optional" Style="{StaticResource MutedLabelStyle}"/>
                            <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushTheme}" BorderThickness="1" CornerRadius="12" Padding="12,10">
                                <TextBlock x:Name="SourceInfoText" Text="Manuelle Erfassung" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                            </Border>
                        </StackPanel>

                        <CheckBox x:Name="NoSupplierInvoiceCheckBox"
                                  Grid.Row="4"
                                  Grid.ColumnSpan="2"
                                  Margin="0,16,0,0"
                                  Content="Ohne Rechnungsbeleg erfassen"
                                  Checked="NoSupplierInvoiceCheckBox_Changed"
                                  Unchecked="NoSupplierInvoiceCheckBox_Changed"/>

                        <TextBlock x:Name="InvoiceDirectionHintText"
                                   Grid.Row="5"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Pflichtfelder im manuellen Import" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="ImportModeInfoText" Text="Rechnungsnummer, Rechnungsdatum, Rechnungsbetrag und PDF sind erforderlich." Foreground="{StaticResource MutedTextBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Artikelnummer, EAN, Lieferant, Metallzuschlag und Brutto-Listenpreis sind optional." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Bei Positionen ohne Lieferantenrechnung bleibt der EK fuer die Kalkulation erhalten, wird aber als Ausgabe ohne aktuellen Beleg gekennzeichnet." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Expander IsExpanded="False">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock Text="Manuelle Positionseintragung" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Nur ausklappen, wenn du Positionen manuell erfassen oder ergaenzen moechtest." Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Expander.Header>

                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,14">
                                <TextBlock Text="Artikelnummer optional" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="ArticleNumberText"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,14,14">
                                <TextBlock Text="EAN optional" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="EanText"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                                <TextBlock Text="Einheit * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                                <TextBox x:Name="UnitText" Text="ST"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,14,14">
                                <TextBlock Text="Beschreibung * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                                <TextBox x:Name="DescriptionText"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                                <TextBlock Text="Menge * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                                <TextBox x:Name="QuantityText" Text="1"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,14,14">
                                <TextBlock Text="Netto-Preis * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                                <TextBox x:Name="NetPriceText" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,14,14">
                                <TextBlock Text="Metallzuschlag optional" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="MetalSurchargeText" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Preisbasis * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                                <TextBox x:Name="PriceBasisText" Text="1"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,14,0">
                                <TextBlock Text="Brutto-Listenpreis optional" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="GrossPriceText" Text="0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock x:Name="VatPercentLabel" Text="MwSt. in % optional" Style="{StaticResource MutedLabelStyle}"/>
                                <TextBox x:Name="VatPercentText" Text="19"/>
                            </StackPanel>
                        </Grid>

                        <WrapPanel Grid.Row="1" Margin="0,18,0,0">
                            <Button Width="170" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Position hinzufuegen" Click="AddManualLine_Click"/>
                        </WrapPanel>
                    </Grid>
                </Expander>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Importierte Rechnungen" Style="{StaticResource SectionTitleStyle}" Margin="18,18,18,0"/>
                    <WrapPanel Grid.Column="1" Margin="0,18,18,0">
                        <Button Width="170" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Prüfrechnung laden" Click="LoadReviewInvoice_Click"/>
                        <Button Width="160" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Rechnung stornieren" Click="CancelInvoice_Click"/>
                        <Button Width="190" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="PDF nachtraeglich hinterlegen" Click="UploadStoredPdf_Click"/>
                        <Button Width="150" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Rechnung ansehen" Click="OpenStoredPdf_Click"/>
                        <Button Width="180" Height="36" Style="{StaticResource SecondaryButtonStyle}" Content="PDFs in Ordner exportieren" Click="ExportStoredPdfs_Click"/>
                    </WrapPanel>
                    <DataGrid x:Name="InvoicesGrid"
                              Grid.Row="1"
                              Grid.ColumnSpan="2"
                              Margin="0,16,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              MinHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rechnung" Binding="{Binding DisplayNumber}" Width="160"/>
                            <DataGridTextColumn Header="Art" Binding="{Binding InvoiceDirectionLabel}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding InvoiceStatusLabel}" Width="90"/>
                            <DataGridTextColumn Header="Datum" Binding="{Binding InvoiceDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Partei" Binding="{Binding SupplierName}" Width="180"/>
                            <DataGridTextColumn Header="Kategorie" Binding="{Binding AccountingCategoryLabel}" Width="150"/>
                            <DataGridTextColumn Header="Beleg" Binding="{Binding ExpenseStatus}" Width="120"/>
                            <DataGridCheckBoxColumn Header="PDF" Binding="{Binding HasStoredPdf}" Width="70"/>
                            <DataGridTextColumn Header="Datei" Binding="{Binding OriginalPdfFileName}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="18,18,18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Positionen der aktuellen Erfassung" Style="{StaticResource SectionTitleStyle}"/>
                        <Button Grid.Column="1"
                                Width="190"
                                Height="36"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Markierte Positionen löschen"
                                Click="RemoveSelectedLine_Click"/>
                    </Grid>
                    <DataGrid x:Name="ManualLinesGrid"
                              Grid.Row="1"
                              Margin="0,16,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CellEditEnding="ManualLinesGrid_CellEditEnding"
                              SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pos." Binding="{Binding Position}" Width="60"/>
                            <DataGridTextColumn Header="Artikel" Binding="{Binding ArticleNumber}" Width="120"/>
                            <DataGridTextColumn Header="EAN" Binding="{Binding Ean}" Width="140"/>
                            <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Menge" Binding="{Binding Quantity}" Width="90"/>
                            <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="80"/>
                            <DataGridTextColumn Header="Gesamtbrutto&#10;pro Einheit" Binding="{Binding GrossUnitPrice, StringFormat={}{0:N2} &#x20AC;}" Width="160"/>
                            <DataGridTextColumn Header="Gesamtnetto&#10;pro Einheit" Binding="{Binding EffectiveNetUnitPrice, StringFormat={}{0:N2} &#x20AC;}" Width="170"/>
                            <DataGridTextColumn Header="Netto&#10;pro Basis" Binding="{Binding NetUnitPrice, StringFormat={}{0:N2} &#x20AC;}" Width="120"/>
                            <DataGridTextColumn Header="Materialzuschlag&#10;pro Basis" Binding="{Binding MetalSurcharge, StringFormat={}{0:N2} &#x20AC;}" Width="170"/>
                            <DataGridTextColumn Header="Basis" Binding="{Binding PriceBasisQuantity}" Width="80"/>
                            <DataGridTextColumn Header="Gesamtpreis&#10;Netto" Binding="{Binding LineTotal, StringFormat={}{0:N2} &#x20AC;}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border x:Name="StatusBorder" Grid.Row="5" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>



