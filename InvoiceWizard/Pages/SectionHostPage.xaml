<Page x:Class="InvoiceWizard.SectionHostPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SectionHostPage">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="SectionTitleText" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock x:Name="SectionDescriptionText" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                <WrapPanel x:Name="SectionButtonsPanel" Margin="0,18,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
            <Frame x:Name="SectionFrame" NavigationUIVisibility="Hidden" Background="Transparent"/>
        </Border>
    </Grid>
</Page>
