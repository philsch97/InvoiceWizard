<Page x:Class="InvoiceWizard.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="860" d:DesignWidth="1200"
      Title="AnalyticsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Auswertung" Style="{StaticResource PageTitleStyle}"/>
                        <TextBlock Text="Bezahlte Umsaetze inkl. USt., erfasste Ausgaben inkl. USt., Gewinn/Verlust und eine Projektuebersicht auf einen Blick." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Width="120" Height="40" Content="Aktualisieren" Click="Refresh_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <WrapPanel>
                    <StackPanel Width="240" Margin="0,0,14,0">
                        <TextBlock Text="Kundenfilter" Style="{StaticResource MutedLabelStyle}"/>
                        <ComboBox x:Name="CustomerFilterCombo" DisplayMemberPath="Name" SelectedValuePath="CustomerId" SelectionChanged="CustomerFilterCombo_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Width="240" Margin="0,0,14,0">
                        <TextBlock Text="Projektfilter" Style="{StaticResource MutedLabelStyle}"/>
                        <ComboBox x:Name="ProjectFilterCombo" DisplayMemberPath="Name" SelectedValuePath="ProjectId" SelectionChanged="ProjectFilterCombo_SelectionChanged"/>
                    </StackPanel>
                    <Button Width="120" Height="40" Margin="0,22,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Filter reset" Click="ResetFilters_Click"/>
                </WrapPanel>
            </Border>

            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Bezahlter Umsatz inkl. USt." Style="{StaticResource MutedLabelStyle}"/>
                        <TextBlock x:Name="RevenueText" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Gefilterte Ausgaben inkl. USt." Style="{StaticResource MutedLabelStyle}"/>
                        <TextBlock x:Name="ExpensesText" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Gewinn / Verlust" Style="{StaticResource MutedLabelStyle}"/>
                        <TextBlock x:Name="ProfitText" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Offen exportiert inkl. USt." Style="{StaticResource MutedLabelStyle}"/>
                        <TextBlock x:Name="OpenRevenueText" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Monatsvergleich" Style="{StaticResource SectionTitleStyle}"/>
                    <ItemsControl x:Name="MonthlyChart" Grid.Row="1" Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Bottom" Margin="8,0">
                                    <Grid Height="220" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="26" VerticalAlignment="Bottom" Fill="{StaticResource SuccessBrush}" Height="{Binding RevenueHeight}" RadiusX="6" RadiusY="6"/>
                                        <Rectangle Grid.Column="1" Width="26" VerticalAlignment="Bottom" Fill="{StaticResource ErrorBrush}" Height="{Binding ExpenseHeight}" RadiusX="6" RadiusY="6"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding Profit, StringFormat={}{0:0.##} EUR}" HorizontalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Ausgaben nach Kategorie" Style="{StaticResource SectionTitleStyle}" Margin="18,18,18,0"/>
                    <DataGrid x:Name="ExpenseCategoryGrid" Grid.Row="1" Margin="0,16,0,0" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" MinHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kategorie" Binding="{Binding AccountingCategoryLabel}" Width="*"/>
                            <DataGridTextColumn Header="Betrag" Binding="{Binding Amount}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Projekte im Ueberblick" Style="{StaticResource SectionTitleStyle}" Margin="18,18,18,0"/>
                    <DataGrid x:Name="ProjectAnalyticsGrid" Grid.Row="1" Margin="0,16,0,0" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" MinHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kunde" Binding="{Binding CustomerName}" Width="180"/>
                            <DataGridTextColumn Header="Projekt" Binding="{Binding ProjectName}" Width="220"/>
                            <DataGridTextColumn Header="Bezahlter Umsatz inkl. USt." Binding="{Binding PaidRevenue}" Width="160"/>
                            <DataGridTextColumn Header="Offen exportiert inkl. USt." Binding="{Binding OpenRevenue}" Width="170"/>
                            <DataGridTextColumn Header="Arbeitsstunden" Binding="{Binding LoggedHours}" Width="110"/>
                            <DataGridTextColumn Header="Offene Positionen" Binding="{Binding OpenItemCount}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" Margin="18,12,18,18" Foreground="{StaticResource MutedTextBrush}" Text="Die Projektansicht zeigt Umsatz inkl. USt., offene exportierte Werte inkl. USt. und erfasste Stunden pro Projekt. Die gefilterten Ausgaben werden proportional aus zugewiesenem Material inklusive USt. berechnet." TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Border x:Name="StatusBorder" Grid.Row="6" Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12" Margin="0,16,0,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource StatusInfoTextBrush}" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
