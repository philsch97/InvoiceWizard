<Window x:Class="InvoiceWizard.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InvoiceWizard Anmeldung"
        Height="760"
        Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="InvoiceWizard" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock x:Name="IntroText"
                           Margin="0,10,0,0"
                           Text="Melde dich an, um auf deine Firmendaten zuzugreifen."
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
        </Border>

        <Border x:Name="StatusBorder"
                Grid.Row="1"
                Margin="0,0,0,18"
                Padding="14,10"
                Style="{StaticResource CardStyle}">
            <TextBlock x:Name="StatusText"
                       Text="Verbindung zum Backend wird geprueft..."
                       Foreground="{StaticResource PrimaryTextBrush}"/>
        </Border>

        <Grid Grid.Row="2">
            <Border x:Name="LoginPanel" Style="{StaticResource CardStyle}" Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Anmeldung" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Mit deiner Firmenkennung kannst du nur auf die Daten deines Mandanten zugreifen." Foreground="{StaticResource MutedTextBrush}"/>

                    <Grid Grid.Row="2" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="E-Mail-Adresse" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="LoginEmailText" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Passwort" Style="{StaticResource RequiredLabelStyle}"/>
                            <PasswordBox x:Name="LoginPasswordBox" Height="42"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox x:Name="RememberInfoCheck"
                              Grid.Row="3"
                              Margin="0,18,0,0"
                              IsChecked="True"
                              IsEnabled="False"
                              Content="Die Anmeldung gilt aktuell nur fuer diese gestartete App-Sitzung."/>

                    <StackPanel Grid.Row="4" Margin="0,26,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelLoginButton" Width="120" Height="42" Margin="0,0,12,0" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
                        <Button x:Name="LoginButton" Width="160" Height="42" Content="Anmelden" Click="Login_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="BootstrapPanel" Visibility="Collapsed" Style="{StaticResource CardStyle}" Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Erstkonfiguration" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Fuer diesen Server existiert noch kein Benutzer. Erstelle jetzt den ersten Admin-Zugang fuer deine Firma." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>

                    <Grid Grid.Row="2" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Firmenname" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="BootstrapTenantText" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Anzeigename" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="BootstrapDisplayNameText" Height="42"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Admin-E-Mail" Style="{StaticResource RequiredLabelStyle}"/>
                            <TextBox x:Name="BootstrapEmailText" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Passwort" Style="{StaticResource RequiredLabelStyle}"/>
                            <PasswordBox x:Name="BootstrapPasswordBox" Height="42"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Passwort wiederholen" Style="{StaticResource RequiredLabelStyle}"/>
                            <PasswordBox x:Name="BootstrapPasswordConfirmBox" Height="42"/>
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="14" Margin="12,0,0,0">
                            <TextBlock Text="Es wird automatisch eine erste Business-Lizenz und ein Admin-Mandant angelegt. Die Detail-Lizenzlogik schalten wir spaeter weiter frei."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="5" Margin="0,26,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelBootstrapButton" Width="120" Height="42" Margin="0,0,12,0" Style="{StaticResource SecondaryButtonStyle}" Content="Beenden" Click="Cancel_Click"/>
                        <Button x:Name="BootstrapButton" Width="180" Height="42" Content="Admin anlegen" Click="Bootstrap_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
