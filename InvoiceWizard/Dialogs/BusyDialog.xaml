<Window x:Class="InvoiceWizard.Dialogs.BusyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bitte warten"
        Width="520"
        Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">
    <Grid Background="{StaticResource WindowGradientBrush}">
        <Border Margin="18"
                Padding="24"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushTheme}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleTextBlock"
                           Text="Bitte warten"
                           Style="{StaticResource SectionTitleStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="MessageTextBlock"
                           Margin="0,12,0,0"
                           Text="Der Vorgang wird ausgeführt."
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <ProgressBar Margin="0,18,0,0" Height="10" IsIndeterminate="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
