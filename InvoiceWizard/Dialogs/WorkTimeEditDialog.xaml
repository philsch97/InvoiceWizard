<Window x:Class="InvoiceWizard.Dialogs.WorkTimeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arbeitszeit bearbeiten"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Arbeitszeit bearbeiten" Style="{StaticResource PageTitleStyle}" FontSize="24"/>
            <TextBlock Text="Admins koennen abgeschlossene Arbeitszeiten hier nachtraeglich korrigieren." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Kunde" Style="{StaticResource MutedLabelStyle}"/>
                <ComboBox x:Name="CustomerCombo" DisplayMemberPath="Name" SelectionChanged="CustomerCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Projekt" Style="{StaticResource MutedLabelStyle}"/>
                <ComboBox x:Name="ProjectCombo" DisplayMemberPath="Name"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Datum" Style="{StaticResource MutedLabelStyle}"/>
                <DatePicker x:Name="WorkDatePicker"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Beschreibung" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="DescriptionText"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Beginn" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="StartTimeText"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Ende" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="EndTimeText"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Pause (Min.)" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="BreakMinutesText"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Stundensatz" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="HourlyRateText"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Anfahrt (km)" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="TravelKilometersText"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Preis / km" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="TravelRateText"/>
            </StackPanel>

            <StackPanel Grid.Row="5" Grid.ColumnSpan="2">
                <TextBlock Text="Kommentar" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="CommentText" Height="110" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button Width="160" Height="40" Margin="0,0,10,0" Content="Aenderungen speichern" Click="Confirm_Click"/>
            <Button Width="120" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
        </WrapPanel>
    </Grid>
</Window>
