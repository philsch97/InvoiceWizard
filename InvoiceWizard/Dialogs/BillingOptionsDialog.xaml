<Window x:Class="InvoiceWizard.Dialogs.BillingOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abrechnungsoptionen"
        Width="520"
        Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Abrechnungsoptionen" Style="{StaticResource PageTitleStyle}" FontSize="24"/>
            <TextBlock x:Name="DialogHintText" Text="Bitte Zuschlag und Kleinmaterial-Einstellungen fuer diesen Vorgang festlegen." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Zuschlag auf Materialkosten in %" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="MarkupPercentText" Text="0"/>
            </StackPanel>

            <StackPanel x:Name="SmallMaterialModePanel" Grid.Row="1" Margin="0,0,0,14">
                <TextBlock Text="Kleinmaterial" Style="{StaticResource MutedLabelStyle}"/>
                <ComboBox x:Name="SmallMaterialModeCombo" SelectedIndex="1">
                    <ComboBoxItem Content="Einzeln berechnen"/>
                    <ComboBoxItem Content="Als Sammelposition"/>
                    <ComboBoxItem Content="Nicht berechnen"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Pauschales Kleinmaterial auf Rechnung netto in €" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="SmallMaterialFlatFeeText" Text="0"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button Width="170" Height="40" Margin="0,0,10,0" Content="Uebernehmen" Click="Confirm_Click"/>
            <Button Width="120" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
        </WrapPanel>
    </Grid>
</Window>
