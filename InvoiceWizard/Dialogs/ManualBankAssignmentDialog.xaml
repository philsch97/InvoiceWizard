<Window x:Class="InvoiceWizard.Dialogs.ManualBankAssignmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ohne Beleg zuordnen"
        Height="260"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Waehle die Kategorie fuer die Zuordnung ohne Beleg." TextWrapping="Wrap"/>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="Kategorie" Style="{StaticResource MutedLabelStyle}"/>
            <ComboBox x:Name="CategoryCombo" Margin="0,8,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="Notiz optional" Style="{StaticResource MutedLabelStyle}"/>
            <TextBox x:Name="NoteText" Margin="0,8,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="120" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
            <Button Width="160" Height="36" Content="Zuordnen" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
