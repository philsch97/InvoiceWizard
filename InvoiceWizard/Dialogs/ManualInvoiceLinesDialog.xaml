<Window x:Class="InvoiceWizard.Dialogs.ManualInvoiceLinesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Positionen bearbeiten"
        Width="1280"
        Height="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Manuelle Positionen bearbeiten" Style="{StaticResource PageTitleStyle}" FontSize="24"/>
            <TextBlock x:Name="InfoText"
                       Text="Hier kannst du Positionen anlegen, anpassen und löschen. Änderungen werden erst nach dem Speichern in den Rechnungsimport übernommen."
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Artikelnummer optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="ArticleNumberText"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,14,14">
                <TextBlock Text="EAN optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="EanText"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                <TextBlock Text="Einheit * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="UnitText" Text="ST"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,14,14">
                <TextBlock Text="Beschreibung * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="DescriptionText"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                <TextBlock Text="Menge * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="QuantityText" Text="1"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Netto-Preis optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="NetPriceText"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,14,14">
                <TextBlock Text="Materialzuschlag optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="MetalSurchargeText" Text="0"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="2">
                <TextBlock Text="Preisbasis * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="PriceBasisText" Text="1"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Brutto-Preis optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="GrossPriceText"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,14,14">
                <TextBlock x:Name="VatPercentLabel" Text="MwSt. in % optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="VatPercentText" Text="19"/>
            </StackPanel>

            <WrapPanel Grid.Row="4" Grid.ColumnSpan="3" Margin="0,6,0,0">
                <Button Width="170" Height="40" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Position hinzufügen" Click="AddLine_Click"/>
                <Button Width="190" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Markierte Positionen löschen" Click="RemoveSelectedLines_Click"/>
            </WrapPanel>
        </Grid>

        <DataGrid x:Name="LinesGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Extended"
                  MinHeight="340">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Pos." Binding="{Binding Position}" IsReadOnly="True" Width="60"/>
                <DataGridTextColumn Header="Artikel" Binding="{Binding ArticleNumber, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="EAN" Binding="{Binding Ean, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Menge" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Einheit" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Gesamtbrutto&#10;pro Einheit" Binding="{Binding GrossUnitPrice, StringFormat={}{0:N2} &#x20AC;}" IsReadOnly="True" Width="160"/>
                <DataGridTextColumn Header="Gesamtnetto&#10;pro Einheit" Binding="{Binding EffectiveNetUnitPrice, StringFormat={}{0:N2} &#x20AC;}" IsReadOnly="True" Width="170"/>
                <DataGridTextColumn Header="Netto&#10;pro Basis" Binding="{Binding NetUnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2} &#x20AC;}" Width="120"/>
                <DataGridTextColumn Header="Materialzuschlag&#10;pro Basis" Binding="{Binding MetalSurcharge, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2} &#x20AC;}" Width="170"/>
                <DataGridTextColumn Header="Brutto-Liste" Binding="{Binding GrossListPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2} &#x20AC;}" Width="120"/>
                <DataGridTextColumn Header="MwSt. %" Binding="{Binding VatPercent, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="Basis" Binding="{Binding PriceBasisQuantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Gesamtpreis&#10;Netto" Binding="{Binding LineTotal, StringFormat={}{0:N2} &#x20AC;}" IsReadOnly="True" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="180" Height="40" Margin="0,0,10,0" Content="Positionen übernehmen" Click="Confirm_Click"/>
            <Button Width="120" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
        </WrapPanel>
    </Grid>
</Window>
