<Window x:Class="InvoiceWizard.Dialogs.GenerateOfferDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Angebot erzeugen"
        Width="760"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Angebot erzeugen" Style="{StaticResource PageTitleStyle}" FontSize="24"/>
            <TextBlock Text="Angebotsnummer, Zeitraum, Aufschlag und Steuermodus kannst du vor dem Export noch anpassen."
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,8,14">
                <TextBlock Text="Angebotsnummer" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="OfferNumberText"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="Kundennummer" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="CustomerNumberText" IsReadOnly="True"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                <TextBlock Text="Kunde" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="CustomerNameText" IsReadOnly="True"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,8,14">
                <TextBlock Text="Angebotsdatum" Style="{StaticResource MutedLabelStyle}"/>
                <DatePicker x:Name="OfferDatePicker"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="Gültig bis" Style="{StaticResource MutedLabelStyle}"/>
                <DatePicker x:Name="ValidUntilDatePicker"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,8,14">
                <TextBlock Text="Materialaufschlag in %" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="MarkupPercentText"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="Umsatzsteuer" Style="{StaticResource MutedLabelStyle}"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <RadioButton x:Name="WithVatRadio" Content="Mit Umsatzsteuer" Margin="0,0,20,0"/>
                    <RadioButton x:Name="WithoutVatRadio" Content="Ohne Umsatzsteuer (§19 UStG)"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
                <TextBlock Text="Betreff / Einleitung" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="SubjectText" AcceptsReturn="True" TextWrapping="Wrap" Height="220" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button Width="170" Height="40" Margin="0,0,10,0" Content="Angebot erzeugen" Click="Confirm_Click"/>
            <Button Width="120" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
        </WrapPanel>
    </Grid>
</Window>
