<Window x:Class="InvoiceWizard.Dialogs.TextPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kommentar eingeben"
        Height="240"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" TextWrapping="Wrap"/>

        <TextBox x:Name="ValueTextBox"
                 Grid.Row="1"
                 Margin="0,14,0,14"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 MaxLength="500"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="120" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
            <Button Width="140" Height="36" Content="Speichern" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
