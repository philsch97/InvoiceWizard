<Window x:Class="InvoiceWizard.Dialogs.CalendarEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termin"
        Width="560"
        Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="DialogTitleText" Text="Termin erstellen" Style="{StaticResource PageTitleStyle}" FontSize="24"/>
            <TextBlock Text="Termin fuer den ausgewaehlten Tag anlegen oder bearbeiten." Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
                <TextBlock Text="Titel * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="TitleText"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Datum * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <DatePicker x:Name="EntryDatePicker"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Ort optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="LocationText"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,14,14">
                <TextBlock Text="Start * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="StartTimeText" Text="08:00"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,14">
                <TextBlock Text="Ende * Pflicht" Style="{StaticResource RequiredLabelStyle}"/>
                <TextBox x:Name="EndTimeText" Text="09:00"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,14">
                <TextBlock Text="Kunde optional" Style="{StaticResource MutedLabelStyle}"/>
                <ComboBox x:Name="CustomerCombo" DisplayMemberPath="Name" SelectedValuePath="CustomerId"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
                <TextBlock Text="Beschreibung optional" Style="{StaticResource MutedLabelStyle}"/>
                <TextBox x:Name="DescriptionText" AcceptsReturn="True" TextWrapping="Wrap" Height="120" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button Width="150" Height="40" Margin="0,0,10,0" Content="Termin speichern" Click="Confirm_Click"/>
            <Button Width="120" Height="40" Style="{StaticResource SecondaryButtonStyle}" Content="Abbrechen" Click="Cancel_Click"/>
        </WrapPanel>
    </Grid>
</Window>
